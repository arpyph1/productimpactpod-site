---
import "../styles/global.css";
import { getSiteConfig } from "@lib/config";
import { buildPublisherSchema, buildWebsiteSchema } from "@lib/publisher";
import { getSiteSetting } from "@lib/supabase";

const cfg = await getSiteConfig();
const seo = (await getSiteSetting("seo")) ?? {};
const gaId = seo.ga_id || cfg.analytics.gaId;

export interface Props {
  title: string;
  description: string;
  canonicalUrl: string;
  ogType?: "website" | "article";
  ogImage?: string | null;
  ogImageAlt?: string | null;
  publishedTime?: string | null;
  modifiedTime?: string | null;
  articleSection?: string | null;
  articleTags?: string[];
  articleAuthor?: string | null;
  twitterSite?: string;
  jsonLd?: object | object[];
  noindex?: boolean;
}

const {
  title,
  description,
  canonicalUrl,
  ogType = "website",
  ogImage,
  ogImageAlt,
  publishedTime,
  modifiedTime,
  articleSection,
  articleTags = [],
  articleAuthor,
  twitterSite = seo.twitter_handle || cfg.social.twitter,
  jsonLd,
  noindex = false,
} = Astro.props;

const defaultOgImage = seo.og_image || `${cfg.url}/og-default.png`;
const fullOgImage = ogImage ?? defaultOgImage;

const publisherSchema = buildPublisherSchema(cfg);
const websiteSchema = buildWebsiteSchema(cfg);
const pageJsonLd = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
const jsonLdBlocks = [publisherSchema, websiteSchema, ...pageJsonLd];

const accentHsl = cfg.accentHsl;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="preconnect" href={import.meta.env.PUBLIC_SUPABASE_URL} crossorigin />
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="preconnect" href="https://www.google-analytics.com" />
    {cfg.social.substack && <link rel="dns-prefetch" href={cfg.social.substack} />}

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    {seo.google_verification && <meta name="google-site-verification" content={seo.google_verification} />}
    {seo.bing_verification && <meta name="msvalidate.01" content={seo.bing_verification} />}
    {seo.yandex_verification && <meta name="yandex-verification" content={seo.yandex_verification} />}
    {seo.pinterest_verification && <meta name="p:domain_verify" content={seo.pinterest_verification} />}

    <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
    <script is:inline define:vars={{ gaId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', gaId);
    </script>

    {/* Dynamic accent color from site config */}
    <style set:html={`:root { --primary: ${accentHsl}; --accent: ${cfg.accentColor}; --accent-hover: ${cfg.accentHover}; --ring: ${accentHsl}; --coral: ${accentHsl}; }`}></style>

    <meta
      name="robots"
      content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"}
    />

    <link rel="icon" type="image/png" sizes="32x32"  href="/favicon.png" />
    <link rel="icon" type="image/png" sizes="96x96"  href="/favicon-96.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={fullOgImage} />
    {ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}
    <meta property="og:site_name" content={cfg.name} />
    <meta property="og:locale" content="en_US" />

    {ogType === "article" && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {ogType === "article" && modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime} />
    )}
    {ogType === "article" && articleSection && (
      <meta property="article:section" content={articleSection} />
    )}
    {ogType === "article" && articleAuthor && (
      <meta property="article:author" content={articleAuthor} />
    )}
    {ogType === "article" &&
      articleTags.map((tag) => (
        <meta property="article:tag" content={tag} />
      ))}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={twitterSite} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImage} />
    {ogImageAlt && <meta name="twitter:image:alt" content={ogImageAlt} />}

    <link rel="alternate" type="application/rss+xml" title={`${cfg.name} — News`} href={`${cfg.url}/news/rss.xml`} />
    <link rel="alternate" type="application/rss+xml" title={`${cfg.name} — Podcast`} href={`${cfg.url}/podcast/rss.xml`} />

    {jsonLdBlocks.map((block) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}
  </head>
  <body class="bg-background text-foreground antialiased font-body">
    <slot />

    {/* Per-session page-count tracker. Runs on every page so all pages count
        towards a session's total. The first article seen in the session is
        captured as landing_article_id (from [data-article-id] on the
        engagement container); subsequent navigations within the same tab
        bump pages_count. */}
    <script is:inline define:vars={{
      sbUrl: import.meta.env.PUBLIC_SUPABASE_URL,
      sbKey: import.meta.env.PUBLIC_SUPABASE_ANON_KEY,
    }}>
      (function() {
        if (!sbUrl || !sbKey) return;
        try {
          var SID_KEY = 'pi_session_id';
          var PAGES_KEY = 'pi_session_pages';
          var LAND_KEY = 'pi_session_landing';
          var sid = sessionStorage.getItem(SID_KEY);
          if (!sid) {
            sid = (crypto && crypto.randomUUID) ? crypto.randomUUID()
              : 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
                  var r = Math.random() * 16 | 0;
                  return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16);
                });
            sessionStorage.setItem(SID_KEY, sid);
          }
          var pages = parseInt(sessionStorage.getItem(PAGES_KEY) || '0', 10) + 1;
          sessionStorage.setItem(PAGES_KEY, String(pages));

          function send(landingId) {
            fetch(sbUrl + '/rest/v1/rpc/upsert_session', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + sbKey, 'apikey': sbKey },
              body: JSON.stringify({ p_session_id: sid, p_landing_article_id: landingId, p_pages_count: pages }),
              keepalive: true,
            }).catch(function() {});
          }

          var landing = sessionStorage.getItem(LAND_KEY);

          function tick() {
            if (!landing) {
              var el = document.querySelector('[data-article-id]');
              var id = el ? el.getAttribute('data-article-id') : null;
              if (id) {
                landing = id;
                sessionStorage.setItem(LAND_KEY, landing);
              }
            }
            if (landing) send(landing);
          }
          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', tick);
          } else {
            tick();
          }
        } catch (e) {}
      })();
    </script>

    <!-- WebMCP: expose site tools to AI agents in the browser (Chrome 137+) -->
    <script is:inline>
      (function () {
        try {
          if (!('modelContext' in navigator) ||
              typeof navigator.modelContext.provideContext !== 'function') return;
          navigator.modelContext.provideContext({
            tools: [
              {
                name: 'get_latest_articles',
                description: 'Get the latest articles from Product Impact as an RSS feed.',
                inputSchema: { type: 'object', properties: {} },
                execute: async function () {
                  return fetch('/rss.xml').then(function (r) { return r.text(); });
                },
              },
              {
                name: 'get_podcast_episodes',
                description: 'Get Product Impact Podcast episodes as an RSS feed.',
                inputSchema: { type: 'object', properties: {} },
                execute: async function () {
                  return fetch('/podcast/rss.xml').then(function (r) { return r.text(); });
                },
              },
              {
                name: 'get_site_context',
                description: 'Get a plain-text overview of Product Impact — topics, taxonomy, content surfaces, and feeds — optimised for language models.',
                inputSchema: { type: 'object', properties: {} },
                execute: async function () {
                  return fetch('/llms.txt').then(function (r) { return r.text(); });
                },
              },
              {
                name: 'get_content_index',
                description: 'Get the full sitemap of all published articles, episodes, and pages.',
                inputSchema: { type: 'object', properties: {} },
                execute: async function () {
                  return fetch('/sitemap.xml').then(function (r) { return r.text(); });
                },
              },
            ],
          });
        } catch (e) {}
      })();
    </script>
  </body>
</html>
