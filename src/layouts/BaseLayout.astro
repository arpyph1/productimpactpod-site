---
// BaseLayout.astro — renders the HTML shell with full server-side meta tags.
// This is the fix for Lovable's client-side meta-tag bug: Astro's frontmatter
// runs at build time, so every meta tag is in the initial HTML response that
// crawlers see.

import "../styles/global.css";
import { publisherSchema, websiteSchema } from "@lib/publisher";

export interface Props {
  title: string;
  description: string;
  canonicalUrl: string;
  ogType?: "website" | "article";
  ogImage?: string | null;
  ogImageAlt?: string | null;
  publishedTime?: string | null;
  modifiedTime?: string | null;
  articleSection?: string | null;
  articleTags?: string[];
  articleAuthor?: string | null;
  twitterSite?: string;
  jsonLd?: object | object[];
  noindex?: boolean;
}

const {
  title,
  description,
  canonicalUrl,
  ogType = "website",
  ogImage,
  ogImageAlt,
  publishedTime,
  modifiedTime,
  articleSection,
  articleTags = [],
  articleAuthor,
  twitterSite = "@productimpactpod",
  jsonLd,
  noindex = false,
} = Astro.props;

const siteUrl = "https://productimpactpod.com";
// PNG generated from src/brand/og-default.svg via scripts/build-brand-assets.mjs
const fullOgImage = ogImage ?? `${siteUrl}/og-default.png`;

// Always include publisher + website schemas on every page.
// Page-specific jsonLd (NewsArticle, PodcastEpisode, CollectionPage, etc.)
// stacks on top. Linking via @id avoids duplication when /about renders its
// own NewsMediaOrganization — Google canonicalises to the same @id.
const pageJsonLd = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
const jsonLdBlocks = [publisherSchema, websiteSchema, ...pageJsonLd];
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Core meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Robots: max-image-preview:large is required for Google Discover -->
    <meta
      name="robots"
      content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"}
    />

    <!-- Favicon set. Browsers pick the best size for their UI. -->
    <link rel="icon" type="image/png" sizes="16x16"  href="/favicon-16.png" />
    <link rel="icon" type="image/png" sizes="32x32"  href="/favicon.png" />
    <link rel="icon" type="image/png" sizes="96x96"  href="/favicon-96.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={fullOgImage} />
    {ogImageAlt && <meta property="og:image:alt" content={ogImageAlt} />}
    <meta property="og:site_name" content="Product Impact" />
    <meta property="og:locale" content="en_US" />

    <!-- Article-specific Open Graph (for news/article pages) -->
    {ogType === "article" && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {ogType === "article" && modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime} />
    )}
    {ogType === "article" && articleSection && (
      <meta property="article:section" content={articleSection} />
    )}
    {ogType === "article" && articleAuthor && (
      <meta property="article:author" content={articleAuthor} />
    )}
    {ogType === "article" &&
      articleTags.map((tag) => (
        <meta property="article:tag" content={tag} />
      ))}

    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={twitterSite} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImage} />
    {ogImageAlt && <meta name="twitter:image:alt" content={ogImageAlt} />}

    <!-- RSS feed discovery -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Product Impact — News"
      href={`${siteUrl}/news/rss.xml`}
    />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Product Impact — Podcast"
      href={`${siteUrl}/podcast/rss.xml`}
    />

    <!-- JSON-LD structured data (server-rendered, crawler-visible) -->
    {jsonLdBlocks.map((block) => (
      <script
        type="application/ld+json"
        set:html={JSON.stringify(block)}
      />
    ))}

  </head>
  <body class="bg-background text-foreground antialiased font-body">
    <slot />
  </body>
</html>
