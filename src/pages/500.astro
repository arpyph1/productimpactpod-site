---
// /500 — server error page.
// This is a static site, so genuine 500s are rare — they can occur if
// Cloudflare Pages partially fails to serve an asset or during edge
// network disruptions. Cloudflare's dashboard lets you configure this
// file as the custom 500 response under Pages → Settings → Functions.

import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";
import Footer from "@components/Footer.astro";

const siteUrl = "https://productimpactpod.com";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Something went wrong | Product Impact",
  url: `${siteUrl}/500`,
  isPartOf: { "@type": "WebSite", name: "Product Impact", url: siteUrl },
};
---

<BaseLayout
  title="Something went wrong | Product Impact"
  description="A server error occurred. This is rare for our static site — please try again in a moment."
  canonicalUrl={`${siteUrl}/500`}
  noindex={true}
  jsonLd={jsonLd}
>
  <Nav />

  <main class="container-wide py-24 max-w-3xl mx-auto text-center">
    <div class="inline-flex items-center px-3 py-1 rounded-full bg-accent/10 border border-accent/30 text-accent text-xs font-bold uppercase tracking-wider mb-6">
      500
    </div>
    <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight text-white mb-6">
      Something went wrong
    </h1>
    <p class="text-xl text-[#d4d4d4] leading-relaxed mb-10">
      A server error kept us from loading this page. This is rare for our
      site — it usually means a temporary hiccup at the edge network. Try
      refreshing in a moment, or head somewhere else.
    </p>

    <div class="flex flex-wrap items-center justify-center gap-3 mb-16">
      <button
        type="button"
        onclick="window.location.reload()"
        class="px-6 py-3 rounded-full bg-accent text-black font-bold text-sm hover:bg-accent-hover transition-colors"
      >
        Try again
      </button>
      <a
        href="/"
        class="px-6 py-3 rounded-full border border-[#3a3a3a] text-sm font-semibold text-[#d4d4d4] hover:text-white hover:border-accent transition-colors"
      >
        Home →
      </a>
      <a
        href="/news/"
        class="px-6 py-3 rounded-full border border-[#3a3a3a] text-sm font-semibold text-[#d4d4d4] hover:text-white hover:border-accent transition-colors"
      >
        Latest news →
      </a>
    </div>

    <section class="pt-10 border-t border-[#2a2a2a] text-left">
      <h2 class="text-sm font-bold text-white mb-3">If the problem persists</h2>
      <p class="text-sm text-[#a0a0a0] leading-relaxed">
        Email{" "}
        <a href="mailto:info@productimpactpod.com" class="text-accent hover:text-accent-hover">
          info@productimpactpod.com
        </a>{" "}
        with the URL you were trying to reach and the approximate time. We
        check these reports and fix issues quickly.
      </p>
      <p class="text-sm text-[#a0a0a0] leading-relaxed mt-3">
        Status of our infrastructure providers:{" "}
        <a href="https://www.cloudflarestatus.com/" target="_blank" rel="noopener" class="text-accent hover:text-accent-hover">
          Cloudflare
        </a>{" "}
        ·{" "}
        <a href="https://status.supabase.com/" target="_blank" rel="noopener" class="text-accent hover:text-accent-hover">
          Supabase
        </a>
      </p>
    </section>
  </main>

  <Footer />
</BaseLayout>
