---
import EntityPage from "@components/EntityPage.astro";
import { getAllEntitiesByType, getEntityBySlug, getArticlesByEntity } from "@lib/supabase";

export async function getStaticPaths() {
  const entities = await getAllEntitiesByType("product");
  return entities.map((e) => ({ params: { slug: e.slug } }));
}

const { slug } = Astro.params;
const [entity, articles] = await Promise.all([
  getEntityBySlug("product", slug),
  getArticlesByEntity(slug),
]);

if (!entity) return Astro.redirect("/404", 302);
---

<EntityPage entity={entity} articles={articles} />
