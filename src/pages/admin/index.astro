---
import "../../styles/global.css";
const siteUrl = "https://productimpactpod.com";
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin | Product Impact</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
    <style>
      @media (max-width: 767px) {
        #admin-root input:not([type="checkbox"]):not([type="radio"]):not([type="color"]):not([type="file"]),
        #admin-root select,
        #admin-root textarea {
          font-size: 16px !important;
        }
      }
      @media (prefers-reduced-motion: reduce) {
        #admin-root *, #admin-root *::before, #admin-root *::after {
          animation-duration: 0.01ms !important;
          transition-duration: 0.01ms !important;
        }
      }
    </style>
  </head>
  <body class="bg-[#080808] text-[#e5e5e5] min-h-screen font-sans antialiased">
    <div id="admin-root"></div>
  </body>
</html>

<script>
  import AdminApp from "@components/admin/AdminApp";
  import React from "react";
  import { createRoot } from "react-dom/client";

  const root = createRoot(document.getElementById("admin-root")!);
  root.render(React.createElement(AdminApp));
</script>
