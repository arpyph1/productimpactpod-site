---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";
import Footer from "@components/Footer.astro";
import StoryCard from "@components/StoryCard.astro";
import { sanitizeHtml } from "@lib/sanitize";
import {
  getAllThemes, getAllArticles, getEpisodesByTheme, getEntitiesByTheme,
  themeLabel, type Theme, type Article, type Entity, type Episode,
} from "@lib/supabase";

export async function getStaticPaths() {
  const THEME_KEYWORDS: Record<string, string[]> = {
    "ai-product-strategy": ["product strategy", "roadmap", "prioriti", "product-market", "product leader", "product manag", "product vision", "strategic", "ship"],
    "adoption-organizational-change": ["adoption", "organizational", "change management", "transformation", "enterprise", "scaling", "resistance", "stakeholder", "workforce", "deploy"],
    "agents-agentic-systems": ["agent", "agentic", "autonomous", "multi-agent", "orchestrat", "copilot", "chatbot"],
    "data-semantics-knowledge-foundations": ["data", "knowledge", "semantic", "ontolog", "taxonomy", "graph", "rag", "retrieval", "embedding", "vector"],
    "evaluation-benchmarking": ["evaluat", "benchmark", "metric", "measur", "kpi", "roi", "testing", "a/b test", "accuracy", "performance"],
    "go-to-market-distribution": ["go-to-market", "gtm", "distribution", "pricing", "monetiz", "growth", "acquisition", "retention", "competitive", "launch"],
    "governance-risk-trust": ["governance", "risk", "trust", "safety", "ethic", "bias", "fairness", "regulat", "compliance", "transparen", "responsible", "guardrail"],
    "ux-experience-design-for-ai": ["ux", "user experience", "design", "interface", "interaction", "usability", "human-centered", "conversational", "prototype"],
  };

  const themes = await getAllThemes();
  const articles = await getAllArticles();
  return themes.map((theme) => {
    const tagged = articles.filter((a) => a.themes?.includes(theme.slug));
    const keywords = THEME_KEYWORDS[theme.slug] ?? [];
    const autoTagged = keywords.length > 0
      ? articles.filter((a) => {
          if (tagged.some(t => t.slug === a.slug)) return false;
          const text = `${a.title} ${a.subtitle ?? ""} ${a.meta_description ?? ""}`.toLowerCase();
          return keywords.some(k => text.includes(k));
        })
      : [];
    return {
      params: { slug: theme.slug },
      props: { theme, articles: [...tagged, ...autoTagged] },
    };
  });
}

const { theme, articles } = Astro.props as { theme: Theme; articles: Article[] };
const siteUrl = "https://productimpactpod.com";
const canonicalUrl = `${siteUrl}/themes/${theme.slug}`;

const episodes = await getEpisodesByTheme(theme.slug, 20);
const themeEntities = await getEntitiesByTheme(theme.slug);
const concepts = themeEntities.filter(e => e.type === "concept");
const people = themeEntities.filter(e => e.type === "person");
const organizations = themeEntities.filter(e => e.type === "organization");
const allThemes = await getAllThemes();
const relatedThemes = allThemes.filter(t => t.slug !== theme.slug);

function stripPlaceholders(text: string | null | undefined): string {
  if (!text) return "";
  return text
    .replace(/\([^)]*(?:Populated|compounds|widget|scoped to|auto[- ]?generat|placeholder|auto[- ]?populat|entities\.yaml|existing theme|episodes in this|episodes tagged)[^)]*\)/gi, "")
    .trim();
}

function cleanLongFormIntro(html: string | null | undefined): string {
  if (!html) return "";
  return html
    .replace(/<p[^>]*>\s*\([^)]*(?:Populated|compounds|widget|scoped to|auto[- ]?generat|placeholder|auto[- ]?populat|entities\.yaml|existing theme|episodes in this|episodes tagged)[^)]*\)\s*<\/p>/gi, "")
    .replace(/\([^)]*(?:Populated|compounds|widget|scoped to|auto[- ]?generat|placeholder|auto[- ]?populat|entities\.yaml|existing theme|episodes in this|episodes tagged)[^)]*\)/gi, "")
    .replace(/<h[2-4][^>]*>\s*(?:Canonical Concepts|Featured People|Key Quotes|Ask the Podcast|Related Themes)\s*<\/h[2-4]>/gi, "")
    .replace(/<h[2-4][^>]*>\s*Episodes Tagged:[^<]*<\/h[2-4]>/gi, "")
    .replace(/<(p|div|section)[^>]*>\s*<\/\1>/g, "")
    .replace(/\n{3,}/g, "\n\n")
    .trim();
}

const themeColors: Record<string, string> = {
  "ai-product-strategy": "#ff6b4a",
  "agents-agentic-systems": "#9b7bff",
  "ux-experience-design-for-ai": "#4ab8c9",
  "adoption-organizational-change": "#f5a623",
  "evaluation-benchmarking": "#6bbf71",
  "go-to-market-distribution": "#ff8566",
  "data-semantics-knowledge-foundations": "#5ba3cc",
  "governance-risk-trust": "#c96bff",
};
const color = themeColors[theme.slug] ?? "#ff6b4a";

const entityTypeUrls: Record<string, string> = {
  concept: "/concepts",
  person: "/people",
  organization: "/organizations",
  product: "/products",
  framework: "/frameworks",
  source: "/sources",
};
---

<BaseLayout
  title={`${theme.name} | Product Impact`}
  description={theme.meta_description ?? theme.description ?? `Articles about ${theme.name}`}
  canonicalUrl={canonicalUrl}
>
  <Nav />

  <main class="max-w-[1200px] mx-auto px-4 md:px-6 py-8">
    {/* Breadcrumb */}
    <nav class="text-[11px] text-[#555] mb-4 flex items-center gap-1.5">
      <a href="/" class="hover:text-white">Home</a>
      <span class="text-[#333]">›</span>
      <a href="/themes/" class="hover:text-white">Themes</a>
      <span class="text-[#333]">›</span>
      <span class="text-[#777]">{theme.name}</span>
    </nav>

    {/* Header with accent bar */}
    <header class="mb-8 pb-6 border-b border-[#181818]">
      <div class="flex items-start gap-3">
        <div class="w-1.5 h-16 rounded-full flex-shrink-0 mt-1" style={`background: ${color}`}></div>
        <div>
          <div class="flex items-baseline gap-2 mb-1">
            <h1 class="text-[28px] md:text-[36px] font-extrabold text-white tracking-tight">{theme.name}</h1>
            <span class="text-[16px] font-bold" style={`color: ${color}`}>{articles.length}</span>
          </div>
          <p class="text-[15px] text-[#999] leading-relaxed max-w-2xl">
            {stripPlaceholders(theme.description)}
          </p>
        </div>
      </div>
    </header>

    {/* Long-form intro (cleaned of placeholders) */}
    {theme.long_form_intro && (() => {
      const cleaned = cleanLongFormIntro(theme.long_form_intro);
      return cleaned ? <div class="article-prose mb-12 max-w-[680px]" set:html={sanitizeHtml(cleaned)}></div> : null;
    })()}

    {/* Articles in this theme */}
    {articles.length > 0 && (
      <section class="mb-12">
        <div class="flex items-baseline gap-2 mb-4">
          <h2 class="text-[18px] font-bold text-white">Articles</h2>
          <span class="text-[13px] font-bold" style={`color: ${color}`}>{articles.length}</span>
        </div>
        {articles.length >= 2 ? (
          <div>
            <div class="mb-4">
              <StoryCard article={articles[0]} size="medium" />
            </div>
            <div class="space-y-1">
              {articles.slice(1).map((a) => (
                <StoryCard article={a} size="compact" />
              ))}
            </div>
          </div>
        ) : (
          <StoryCard article={articles[0]} size="medium" />
        )}
      </section>
    )}

    {/* Episodes tagged with this theme */}
    {episodes.length > 0 && (
      <section class="mb-12">
        <div class="flex items-baseline gap-2 mb-4">
          <h2 class="text-[18px] font-bold text-white">Episodes: {theme.name}</h2>
          <span class="text-[13px] font-bold" style={`color: ${color}`}>{episodes.length}</span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          {episodes.map((ep) => (
            <a href={ep.slug ? `/episodes/${ep.slug}/` : "#"} class="group block p-4 bg-[#0c0c0c] border border-[#1a1a1a] rounded-xl hover:border-[#333] transition-colors">
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5" style={`background: ${color}20`}>
                  <span class="text-[12px] font-bold" style={`color: ${color}`}>{ep.episode_number ?? "•"}</span>
                </div>
                <div class="min-w-0">
                  <h3 class="text-[14px] font-semibold text-[#ccc] group-hover:text-white leading-snug line-clamp-2 transition-colors">{ep.title}</h3>
                  {ep.duration && <span class="text-[11px] text-[#555] mt-1 block">{ep.duration}</span>}
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {/* Canonical Concepts */}
    {concepts.length > 0 && (
      <section class="mb-12">
        <h2 class="text-[18px] font-bold text-white mb-4">Canonical Concepts</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          {concepts.map((c) => (
            <a href={`${entityTypeUrls[c.type]}/${c.slug}/`} class="group block p-4 bg-[#0c0c0c] border border-[#1a1a1a] rounded-xl hover:border-[#333] transition-colors">
              <h3 class="text-[14px] font-semibold text-white mb-1">{c.name}</h3>
              {c.description && <p class="text-[12px] text-[#777] leading-relaxed line-clamp-2">{stripPlaceholders(c.description)}</p>}
            </a>
          ))}
        </div>
      </section>
    )}

    {/* Featured People */}
    {people.length > 0 && (
      <section class="mb-12">
        <h2 class="text-[18px] font-bold text-white mb-4">Featured People</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          {people.map((p) => (
            <a href={`/people/${p.slug}/`} class="group block p-4 bg-[#0c0c0c] border border-[#1a1a1a] rounded-xl hover:border-[#333] transition-colors">
              <h3 class="text-[14px] font-semibold text-white mb-1">{p.name}</h3>
              {p.description && <p class="text-[12px] text-[#777] leading-relaxed line-clamp-2">{stripPlaceholders(p.description)}</p>}
            </a>
          ))}
        </div>
      </section>
    )}

    {/* Organizations */}
    {organizations.length > 0 && (
      <section class="mb-12">
        <h2 class="text-[18px] font-bold text-white mb-4">Organizations</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          {organizations.map((o) => (
            <a href={`/organizations/${o.slug}/`} class="group block p-4 bg-[#0c0c0c] border border-[#1a1a1a] rounded-xl hover:border-[#333] transition-colors">
              <h3 class="text-[14px] font-semibold text-white mb-1">{o.name}</h3>
              {o.description && <p class="text-[12px] text-[#777] leading-relaxed line-clamp-2">{stripPlaceholders(o.description)}</p>}
            </a>
          ))}
        </div>
      </section>
    )}

    {/* Related Themes */}
    <section class="mb-12">
      <h2 class="text-[18px] font-bold text-white mb-4">Related Themes</h2>
      <div class="flex flex-wrap gap-2">
        {relatedThemes.map((t) => {
          const tc = themeColors[t.slug] ?? "#ff6b4a";
          return (
            <a href={`/themes/${t.slug}/`}
              class="px-4 py-2 rounded-lg text-[13px] font-medium border transition-colors hover:text-white"
              style={`border-color: ${tc}40; color: ${tc}; background: ${tc}10`}>
              {t.name}
            </a>
          );
        })}
      </div>
    </section>

    {articles.length === 0 && episodes.length === 0 && concepts.length === 0 && people.length === 0 && (
      <p class="text-[#666] py-12 text-center">No content in this theme yet. Content is automatically populated as articles and episodes are tagged with this theme.</p>
    )}
  </main>

  <Footer />
</BaseLayout>
