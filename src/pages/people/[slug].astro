---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";
import Footer from "@components/Footer.astro";
import StoryCard from "@components/StoryCard.astro";
import { supabase, getAllArticles, type Entity, type ArticleSummary } from "@lib/supabase";

export async function getStaticPaths() {
  const { data: entities } = await supabase.from("entities").select("*").eq("type", "person");
  const articles = await getAllArticles();
  return (entities ?? []).map((e: Entity) => ({
    params: { slug: e.slug },
    props: {
      entity: e,
      articles: articles.filter((a) =>
        a.people?.includes(e.slug) || a.author_slugs?.includes(e.slug)
      ),
    },
  }));
}

const { entity, articles } = Astro.props as { entity: Entity; articles: ArticleSummary[] };
const siteUrl = "https://productimpactpod.com";
const canonicalUrl = `${siteUrl}/people/${entity.slug}/`;

// Hardcoded LinkedIn URLs for the show's two hosts. Kept in sync with
// AUTHOR_LINKEDIN in news/[slug].astro and HOSTS in Hosts.astro.
const HOST_LINKEDIN: Record<string, string> = {
  "arpy-dragffy":   "https://www.linkedin.com/in/adragffy/",
  "brittany-hobbs": "https://www.linkedin.com/in/brittanyhobbs/",
};
const hostLinkedIn = HOST_LINKEDIN[entity.slug];

const jsonLd = {
  "@context": "https://schema.org", "@type": "Person",
  name: entity.name, url: canonicalUrl,
  description: entity.description ?? undefined,
  jobTitle: (entity.metadata as any)?.role ?? undefined,
};
---

<BaseLayout
  title={`${entity.name} | Product Impact`}
  description={entity.description ?? `${entity.name} — profile and articles on Product Impact.`}
  canonicalUrl={canonicalUrl}
  jsonLd={jsonLd}
>
  <Nav />

  <main class="max-w-[1200px] mx-auto px-4 md:px-6 py-8">
    <nav class="text-[11px] text-[#555] mb-4 flex items-center gap-1.5">
      <a href="/" class="hover:text-white">Home</a>
      <span class="text-[#333]">›</span>
      <a href="/people/" class="hover:text-white">People</a>
      <span class="text-[#333]">›</span>
      <span class="text-[#777]">{entity.name}</span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_340px] gap-8">
      {/* Main content */}
      <div>
        <header class="mb-8 pb-6 border-b border-[#181818]">
          <div class="flex items-start gap-4">
            <div class="w-16 h-16 rounded-full bg-[#1a1a1a] flex items-center justify-center flex-shrink-0">
              <span class="text-[22px] font-bold text-[#ff6b4a]">{entity.name.charAt(0)}</span>
            </div>
            <div>
              <h1 class="text-[28px] md:text-[36px] font-extrabold text-white tracking-tight mb-1">{entity.name}</h1>
              {(entity.metadata as any)?.role && (
                <p class="text-[14px] text-[#888]">{(entity.metadata as any).role}</p>
              )}
              {hostLinkedIn && (
                <a href={hostLinkedIn} target="_blank" rel="noopener"
                  aria-label={`${entity.name} on LinkedIn`}
                  class="inline-flex items-center gap-1.5 mt-2 px-2.5 py-1 rounded-md bg-[#0a66c2] text-white text-[12px] font-semibold hover:bg-[#0a5aaa] transition-colors">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                  LinkedIn
                </a>
              )}
            </div>
          </div>
        </header>

        {entity.description && (
          <p class="text-[16px] text-[#ccc] leading-relaxed mb-8 max-w-[640px]">{entity.description}</p>
        )}

        {entity.long_form && (
          <div class="article-prose mb-12" set:html={entity.long_form}></div>
        )}

        {/* External links */}
        {entity.external_links?.length > 0 && (
          <div class="mb-8">
            <h2 class="text-[14px] font-bold text-white mb-3">Links</h2>
            <div class="flex flex-wrap gap-2">
              {entity.external_links.map((link) => (
                <a href={link.url} target="_blank" rel="noopener" class="text-[12px] text-[#ff6b4a] hover:text-white px-3 py-1.5 rounded-lg bg-[#0c0c0c] border border-[#1a1a1a] transition-colors">
                  {link.label} ↗
                </a>
              ))}
            </div>
          </div>
        )}
      </div>

      {/* Sidebar: articles by/about this person */}
      <aside>
        {articles.length > 0 && (
          <div class="sticky top-20">
            <div class="flex items-baseline gap-2 mb-3 pb-2 border-b border-[#181818]">
              <span class="text-[14px] font-bold text-white">Articles</span>
              <span class="text-[13px] font-bold text-[#ff6b4a]">{articles.length}</span>
            </div>
            {articles.map((a) => (
              <StoryCard article={a} size="compact" />
            ))}
          </div>
        )}
      </aside>
    </div>
  </main>

  <Footer />
</BaseLayout>
