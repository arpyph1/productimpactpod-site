---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";
import Footer from "@components/Footer.astro";
import { getAllEpisodes, getEpisodeBySlug, getAllArticles, themeLabel } from "@lib/supabase";
import EntityHeadline from "@components/EntityHeadline.astro";

export async function getStaticPaths() {
  const episodes = await getAllEpisodes();
  return episodes
    .filter((ep) => ep.slug)
    .map((ep) => ({ params: { slug: ep.slug! } }));
}

const { slug } = Astro.params;
const episode = await getEpisodeBySlug(slug!);
if (!episode) return Astro.redirect("/episodes/");

const siteUrl = "https://productimpactpod.com";
const epNum = episode.episode_number
  ? `S${String(episode.season_number ?? 2).padStart(2, "0")}E${String(episode.episode_number).padStart(2, "0")}`
  : "";

// Theme colors
const themeColors: Record<string, string> = {
  "ai-product-strategy": "#ff6b4a",
  "agents-agentic-systems": "#9b7bff",
  "ux-experience-design-for-ai": "#4ab8c9",
  "adoption-organizational-change": "#f5a623",
  "evaluation-benchmarking": "#6bbf71",
  "go-to-market-distribution": "#ff8566",
  "data-semantics-knowledge-foundations": "#5ba3cc",
  "governance-risk-trust": "#c96bff",
};

// Related articles that reference this episode
const allArticles = await getAllArticles();
const relatedArticles = allArticles.filter(
  (a) => a.primary_podcast_episode_guid === episode.episode_guid
).slice(0, 3);

// Platform links
const show = {
  spotify: "https://open.spotify.com/show/3O11vQKPpKI5ZlJhdRGwnf",
  apple: "https://podcasts.apple.com/us/podcast/product-impact-podcast-formerly-design-of-ai/id1734499859",
  youtube: "https://www.youtube.com/channel/UCb1nY02YcJYZZ_XtvcIBcrw",
};

// JSON-LD
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "PodcastEpisode",
    name: episode.title,
    description: episode.meta_description ?? "",
    url: `${siteUrl}/episodes/${slug}`,
    datePublished: episode.published_at,
    duration: episode.duration ? `PT${episode.duration.replace(/:/g, "H").replace(/H(\d+)H/, "H$1M")}S` : undefined,
    episodeNumber: episode.episode_number,
    partOfSeason: episode.season_number ? {
      "@type": "CreativeWorkSeason",
      seasonNumber: episode.season_number,
    } : undefined,
    partOfSeries: {
      "@type": "PodcastSeries",
      name: "Product Impact Podcast",
      url: `${siteUrl}/podcast`,
    },
    ...(episode.hosts?.length ? {
      author: episode.hosts.map((h) => ({
        "@type": "Person",
        name: h.replace(/-/g, " ").replace(/\b\w/g, (c: string) => c.toUpperCase()),
      })),
    } : {}),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
      { "@type": "ListItem", position: 2, name: "Episodes", item: `${siteUrl}/episodes` },
      { "@type": "ListItem", position: 3, name: episode.title },
    ],
  },
];
---

<BaseLayout
  title={`${episode.title} | Product Impact Podcast`}
  description={episode.meta_description ?? `Listen to ${episode.title} on the Product Impact Podcast.`}
  canonicalUrl={`${siteUrl}/episodes/${slug}`}
  jsonLd={jsonLd}
>
  <Nav />

  <main class="max-w-[1200px] mx-auto px-4 md:px-6 py-8">

    {/* Breadcrumb */}
    <nav class="flex items-center gap-1.5 text-[12px] text-[#555] mb-6">
      <a href="/" class="hover:text-white transition-colors">Home</a>
      <span>›</span>
      <a href="/episodes/" class="hover:text-white transition-colors">Episodes</a>
      <span>›</span>
      <span class="text-[#888] truncate max-w-[300px]">{episode.title}</span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_340px] gap-8">

      {/* Main column */}
      <div>

        {/* Episode header */}
        <div class="mb-8">
          {/* Episode number + duration */}
          <div class="flex items-center gap-3 mb-4">
            {epNum && (
              <span class="text-[12px] font-bold text-[#ff6b4a] uppercase tracking-wider">{epNum}</span>
            )}
            {episode.duration && (
              <span class="text-[12px] text-[#555]">{episode.duration}</span>
            )}
            {episode.published_at && (
              <span class="text-[12px] text-[#555]">
                {new Date(episode.published_at).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
              </span>
            )}
          </div>

          <h1 class="text-[28px] md:text-[36px] font-extrabold text-white leading-[1.15] tracking-tight mb-4">
            {episode.title}
          </h1>

          {/* Theme badges */}
          {episode.themes?.length > 0 && (
            <div class="flex flex-wrap gap-2 mb-5">
              {episode.themes.map((t) => {
                const c = themeColors[t] ?? "#ff6b4a";
                return (
                  <a href={`/themes/${t}/`} class="text-[11px] font-semibold uppercase tracking-wider px-2 py-1 rounded" style={`color: ${c}; background: ${c}10; border: 1px solid ${c}20`}>
                    {themeLabel(t)}
                  </a>
                );
              })}
            </div>
          )}

          {/* Meta description */}
          {episode.meta_description && (
            <p class="text-[16px] text-[#999] leading-relaxed mb-5">{episode.meta_description}</p>
          )}

          {/* Listen links */}
          <div class="flex flex-wrap gap-3 mb-6">
            {episode.links?.map((l) => (
              <a href={l.url} target="_blank" rel="noopener"
                class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-[#161616] border border-[#222] text-[12px] font-semibold text-[#ccc] hover:text-white hover:border-[#333] transition-colors">
                {l.label}
              </a>
            ))}
            {(!episode.links || episode.links.length === 0) && (
              <>
                <a href={show.spotify} target="_blank" rel="noopener"
                  class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-[#1DB954]/10 border border-[#1DB954]/20 text-[12px] font-semibold text-[#1DB954] hover:bg-[#1DB954]/20 transition-colors">
                  Listen on Spotify
                </a>
                <a href={show.apple} target="_blank" rel="noopener"
                  class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-[#BC5FE8]/10 border border-[#BC5FE8]/20 text-[12px] font-semibold text-[#BC5FE8] hover:bg-[#BC5FE8]/20 transition-colors">
                  Apple Podcasts
                </a>
                <a href={show.youtube} target="_blank" rel="noopener"
                  class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-[#FF0000]/10 border border-[#FF0000]/20 text-[12px] font-semibold text-[#FF4444] hover:bg-[#FF0000]/20 transition-colors">
                  YouTube
                </a>
              </>
            )}
          </div>
        </div>

        {/* Guests */}
        {episode.guests?.length > 0 && (
          <div class="mb-8 p-5 rounded-xl bg-[#0c0c0c] border border-[#1c1c1c]">
            <h2 class="text-[14px] font-bold uppercase tracking-wider text-[#ff6b4a] mb-4">
              {episode.guests.length === 1 ? "Guest" : "Guests"}
            </h2>
            <div class="space-y-4">
              {episode.guests.map((g) => (
                <div class="flex items-start gap-3">
                  <div class="w-10 h-10 rounded-full bg-[#1a1a1a] border border-[#222] flex items-center justify-center flex-shrink-0">
                    <span class="text-[14px] font-bold text-[#666]">{g.name.split(' ').map((n: string) => n[0]).join('')}</span>
                  </div>
                  <div>
                    <div class="text-[15px] font-semibold text-white">{g.name}</div>
                    {g.role && <div class="text-[13px] text-[#888]">{g.role}</div>}
                    <div class="flex gap-3 mt-1">
                      {g.linkedin && (
                        <a href={g.linkedin} target="_blank" rel="noopener" class="text-[11px] text-[#666] hover:text-[#0077B5] transition-colors">LinkedIn</a>
                      )}
                      {g.website && (
                        <a href={g.website} target="_blank" rel="noopener" class="text-[11px] text-[#666] hover:text-[#ff6b4a] transition-colors">Website</a>
                      )}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        {/* Show notes body */}
        {episode.content_html && (
          <div class="article-prose" set:html={episode.content_html} />
        )}

        {/* Transcript */}
        {episode.transcript_markdown && (
          <details class="mt-10 border-t border-[#1c1c1c] pt-6">
            <summary class="flex items-center justify-between cursor-pointer list-none group">
              <span class="text-[16px] font-bold text-[#ddd] group-hover:text-white transition-colors">Full Transcript</span>
              <svg class="w-4 h-4 text-[#555] group-open:rotate-180 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
            </summary>
            <div class="mt-4 text-[14px] text-[#999] leading-relaxed whitespace-pre-wrap">
              {episode.transcript_markdown}
            </div>
          </details>
        )}

      </div>

      {/* Sidebar */}
      <aside class="hidden lg:block">
        <div class="sticky top-16 space-y-6">

          {/* Hosts */}
          <div class="p-4 rounded-xl bg-[#0c0c0c] border border-[#161616]">
            <h3 class="text-[11px] font-bold uppercase tracking-wider text-[#555] mb-3">Hosts</h3>
            <div class="space-y-3">
              {[
                { name: "Arpy Dragffy", role: "Founder, PH1 Research", slug: "arpy-dragffy" },
                { name: "Brittany Hobbs", role: "Co-host", slug: "brittany-hobbs" },
              ].map((host) => (
                <div class="flex items-center gap-2.5">
                  <div class="w-8 h-8 rounded-full bg-[#1a1a1a] border border-[#222] flex items-center justify-center flex-shrink-0">
                    <span class="text-[10px] font-bold text-[#666]">{host.name.split(' ').map((n) => n[0]).join('')}</span>
                  </div>
                  <div>
                    <a href={`/people/${host.slug}/`} class="text-[13px] font-semibold text-[#ccc] hover:text-white transition-colors">{host.name}</a>
                    <div class="text-[11px] text-[#555]">{host.role}</div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          {/* Related articles */}
          {relatedArticles.length > 0 && (
            <div class="p-4 rounded-xl bg-[#0c0c0c] border border-[#161616]">
              <h3 class="text-[11px] font-bold uppercase tracking-wider text-[#555] mb-3">Related Articles</h3>
              <div class="space-y-3">
                {relatedArticles.map((a) => (
                  <a href={`/news/${a.slug}/`} class="block group">
                    <EntityHeadline title={a.title}
                      entities={[...(a.people ?? []), ...(a.organizations ?? []), ...(a.products ?? [])]}
                      tag="span"
                      class="text-[13px] font-semibold text-[#ccc] group-hover:text-white transition-colors leading-snug line-clamp-2 mb-1 block" />
                    <div class="text-[11px] text-[#555]">{a.publish_date}</div>
                  </a>
                ))}
              </div>
            </div>
          )}

          {/* Subscribe CTA */}
          <div class="p-4 rounded-xl bg-[#ff6b4a]/5 border border-[#ff6b4a]/10">
            <h3 class="text-[13px] font-bold text-white mb-1.5">Never miss an episode</h3>
            <p class="text-[12px] text-[#888] mb-3 leading-relaxed">AI product impact news delivered weekly.</p>
            <a href="https://productimpactpod.substack.com" target="_blank" rel="noopener"
              class="block text-center px-4 py-2 rounded-lg bg-[#ff6b4a] hover:bg-[#ff8566] text-white text-[12px] font-semibold transition-colors">
              Subscribe
            </a>
          </div>

        </div>
      </aside>

    </div>
  </main>

  <Footer />
</BaseLayout>
