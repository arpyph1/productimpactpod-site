---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";
import Footer from "@components/Footer.astro";
import { fetchPodcastEpisodes } from "@lib/rss";

const episodes = await fetchPodcastEpisodes(50);
const siteUrl = "https://productimpactpod.com";
---

<BaseLayout
  title="Episodes | Product Impact Podcast"
  description="Browse all episodes of the Product Impact Podcast — interviews with AI product leaders."
  canonicalUrl={`${siteUrl}/episodes`}
>
  <Nav />

  <main class="max-w-[1200px] mx-auto px-4 md:px-6 py-8">
    <header class="mb-8">
      <div class="flex items-baseline gap-2 mb-1">
        <h1 class="text-[28px] md:text-[36px] font-extrabold text-white tracking-tight">Episodes</h1>
        <span class="text-[16px] font-bold text-[#ff6b4a]">{episodes.length}</span>
      </div>
      <p class="text-[14px] text-[#777]">All episodes of the Product Impact Podcast.</p>
    </header>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4" id="episodes-grid">
      {episodes.map((ep, i) => {
        const epLabel = ep.episodeNumber ? `EP ${ep.episodeNumber}` : "";
        const date = ep.pubDate ? new Date(ep.pubDate).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" }) : "";
        return (
          <a href={ep.link || "#"} target="_blank" rel="noopener" class={`group block ${i >= 20 ? 'hidden' : ''}`} data-ep-item>
            <div class="relative aspect-square rounded-xl overflow-hidden mb-2 border border-[#1c1c1c]">
              {ep.imageUrl ? (
                <img src={ep.imageUrl} alt={ep.title} class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500" loading={i < 8 ? "eager" : "lazy"} />
              ) : (
                <div class="w-full h-full bg-[#111] flex items-center justify-center"><span class="text-[36px]">🎙</span></div>
              )}
              <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                <div class="w-12 h-12 rounded-full bg-white/90 flex items-center justify-center shadow-xl">
                  <svg class="w-5 h-5 text-black ml-0.5" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                </div>
              </div>
              {epLabel && <div class="absolute bottom-2 left-2 text-[10px] font-bold text-white bg-black/60 backdrop-blur-sm px-2 py-0.5 rounded">{epLabel}</div>}
            </div>
            <h3 class="text-[13px] font-semibold text-[#ccc] group-hover:text-white leading-snug line-clamp-2 mb-1 transition-colors">{ep.title}</h3>
            <div class="text-[11px] text-[#555]">{date}</div>
          </a>
        );
      })}
    </div>

    {episodes.length > 20 && (
      <div class="text-center mt-8">
        <button id="episodes-load-more" class="text-[13px] text-[#888] hover:text-white font-medium border border-[#222] rounded-full px-6 py-2.5 transition-colors">
          ↓ Load more episodes
        </button>
      </div>
    )}
  </main>

  <Footer />
</BaseLayout>

<script is:inline>
(function() {
  var btn = document.getElementById('episodes-load-more');
  var grid = document.getElementById('episodes-grid');
  if (!btn || !grid) return;
  btn.addEventListener('click', function() {
    var hidden = grid.querySelectorAll('a.hidden');
    var toShow = Math.min(20, hidden.length);
    for (var i = 0; i < toShow; i++) { hidden[i].classList.remove('hidden'); }
    if (grid.querySelectorAll('a.hidden').length === 0) { btn.style.display = 'none'; }
  });
})();
</script>
