---
// /news/{slug} — Particle.news-inspired article page.
// Two-column: overview + body left, related articles sidebar right.
// Server-rendered with full meta tags for crawlers.

import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";
import Footer from "@components/Footer.astro";
import EntityHeadline from "@components/EntityHeadline.astro";
import StoryCard from "@components/StoryCard.astro";
import { sanitizeHtml } from "@lib/sanitize";
import {
  getAllArticles, authorDisplayName,
  formatLabel, themeLabel, stripFirstH1, generateOverviewBullets,
  type Article,
} from "@lib/supabase";
import { fetchPodcastEpisodes } from "@lib/rss";

export async function getStaticPaths() {
  const articles = await getAllArticles();
  return articles.map((a) => ({ params: { slug: a.slug }, props: { article: a, allArticles: articles } }));
}

const { article, allArticles } = Astro.props as { article: Article; allArticles: Article[] };
const related = (() => {
  const others = allArticles.filter(a => a.slug !== article.slug && a.published);
  if (!article.themes || article.themes.length === 0) {
    return others.slice(0, 6);
  }
  const themeSet = new Set(article.themes);
  const scored = others.map(a => ({
    article: a,
    overlap: (a.themes ?? []).filter(t => themeSet.has(t)).length,
  }));
  scored.sort((a, b) => b.overlap - a.overlap || new Date(b.article.publish_date).getTime() - new Date(a.article.publish_date).getTime());
  return scored.slice(0, 6).map(s => s.article);
})();
const latestEpisodes = await fetchPodcastEpisodes(5);

const siteUrl = "https://productimpactpod.com";
const articleUrl = `${siteUrl}/news/${article.slug}`;

const cleanedHtml = sanitizeHtml(stripFirstH1(article.content_html));
const bullets = article.overview_bullets?.length
  ? article.overview_bullets
  : generateOverviewBullets(article.content_html);
const canonicalUrl = article.canonical_url?.startsWith(siteUrl)
  ? article.canonical_url : `${siteUrl}/news/${article.slug}`;

const authorNames = (article.author_slugs ?? []).map(authorDisplayName);
const pubDate = new Date(article.publish_date);
const pubISO = pubDate.toISOString();
const pubFormatted = pubDate.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" });

const shareDesc = article.meta_description ?? article.subtitle ?? '';
const twitterShareText = `${article.title}${shareDesc ? '\n\n' + shareDesc.slice(0, 180) : ''}\n\n${articleUrl}`;
const linkedinSummary = shareDesc + (bullets.length > 0 ? '\n\n' + bullets.slice(0, 2).map((b: string) => '• ' + b).join('\n') : '');

function timeAgo(d: string): string {
  const days = Math.floor((Date.now() - new Date(d).getTime()) / 86400000);
  if (days === 0) return "Today";
  if (days === 1) return "1d ago";
  if (days < 30) return `${days}d ago`;
  return `${Math.floor(days / 30)}mo ago`;
}

const jsonLd = article.schema_jsonld ?? {
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  headline: article.title,
  alternativeHeadline: article.subtitle ?? undefined,
  description: article.meta_description,
  datePublished: pubISO,
  dateModified: article.last_updated ? new Date(article.last_updated).toISOString() : pubISO,
  image: article.hero_image_url ? [article.hero_image_url] : undefined,
  author: authorNames.map((n, i) => ({
    "@type": "Person", name: n, url: `${siteUrl}/people/${article.author_slugs[i]}/`,
    sameAs: article.author_slugs[i] === "arpy-dragffy"
      ? ["https://www.linkedin.com/in/arpydragffy/", "https://ph1.ca"]
      : article.author_slugs[i] === "brittany-hobbs"
      ? ["https://www.linkedin.com/in/brittanyhobbs/"]
      : undefined,
  })),
  publisher: {
    "@type": "NewsMediaOrganization",
    name: "Product Impact",
    url: siteUrl,
    logo: { "@type": "ImageObject", url: `${siteUrl}/logo.png`, width: 600, height: 600 },
    sameAs: [
      "https://www.linkedin.com/company/product-impact-podcast",
      "https://www.youtube.com/channel/UCb1nY02YcJYZZ_XtvcIBcrw",
      "https://productimpactpod.substack.com",
    ],
  },
  mainEntityOfPage: { "@type": "WebPage", "@id": canonicalUrl },
  wordCount: article.word_count ?? undefined,
  articleSection: article.themes?.[0]?.replace(/-/g, " ").replace(/\b\w/g, (c: string) => c.toUpperCase()) ?? undefined,
  keywords: [...(article.themes ?? []), ...(article.topics ?? [])].join(", ") || undefined,
  isAccessibleForFree: true,
  inLanguage: "en",
  speakable: {
    "@type": "SpeakableSpecification",
    cssSelector: ["h1", ".article-prose p:first-of-type"],
  },
  copyrightHolder: { "@type": "Organization", name: "Product Impact" },
  copyrightYear: pubDate.getFullYear(),
};

const bcJsonLd = {
  "@context": "https://schema.org", "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
    { "@type": "ListItem", position: 2, name: "News", item: `${siteUrl}/news` },
    { "@type": "ListItem", position: 3, name: article.title, item: canonicalUrl },
  ],
};
---

<BaseLayout
  title={`${article.title} | Product Impact`}
  description={article.meta_description}
  canonicalUrl={canonicalUrl}
  ogType="article"
  ogImage={article.hero_image_url}
  ogImageAlt={article.hero_image_alt}
  publishedTime={pubISO}
  modifiedTime={article.last_updated ?? pubISO}
  articleSection={article.themes?.[0] ?? null}
  articleTags={article.topics ?? []}
  articleAuthor={`${siteUrl}/people/${article.author_slugs?.[0] ?? "arpy-dragffy"}`}
  jsonLd={[jsonLd, bcJsonLd]}
>
  <Nav />

  <main class="max-w-[1200px] mx-auto px-4 md:px-6 pt-6 pb-16">

    {/* ── Particle-style two-column layout ── */}
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_340px] gap-8 lg:gap-12">

      {/* ════ LEFT COLUMN: article ════ */}
      <div class="min-w-0">

        {/* Breadcrumb */}
        <nav class="text-[11px] text-[#555] mb-4 flex items-center gap-1.5">
          <a href="/" class="hover:text-white">Home</a>
          <span class="text-[#333]">›</span>
          <a href="/news" class="hover:text-white">News</a>
          <span class="text-[#333]">›</span>
          <span class="text-[#777] truncate max-w-[200px]">{article.title}</span>
        </nav>

        {/* Metadata row — Particle style: format + time + themes inline */}
        <div class="flex items-center gap-2 mb-3">
          <span class="text-[10px] font-bold uppercase tracking-wider text-[#ff6b4a]">
            {formatLabel(article.format)}
          </span>
          <span class="text-[10px] text-[#444]">·</span>
          <span class="text-[10px] text-[#555]">{timeAgo(article.publish_date)}</span>
          {article.themes?.map((t) => (
            <>
              <span class="text-[10px] text-[#333]">·</span>
              <a href={`/themes/${t}/`} class="text-[10px] text-[#555] hover:text-[#ff6b4a] transition-colors">
                {themeLabel(t)}
              </a>
            </>
          ))}
        </div>

        {/* H1 headline — entity names highlighted in coral, Particle signature */}
        <EntityHeadline
          title={article.title}
          entities={[...(article.people ?? []), ...(article.organizations ?? []), ...(article.products ?? [])]}
          tag="h1"
          class="text-[32px] md:text-[40px] lg:text-[48px] font-extrabold text-white leading-[1.08] tracking-[-0.03em] mb-3"
        />

        {/* Deck */}
        {article.subtitle && (
          <p class="text-[16px] md:text-[18px] text-[#999] leading-relaxed mb-4 max-w-[640px]">
            {article.subtitle}
          </p>
        )}

        {/* Author + date + share row */}
        <div class="flex items-center justify-between py-4 mb-6 border-t border-b border-[#1a1a1a]">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-[#1a1a1a] flex items-center justify-center flex-shrink-0">
              <span class="text-[11px] font-bold text-[#ff6b4a]">{authorNames[0]?.charAt(0) ?? "A"}</span>
            </div>
            <div class="text-[12px]">
              <a href={`/people/${article.author_slugs?.[0] ?? "arpy-dragffy"}/`} class="text-[#ff6b4a] font-semibold hover:text-white transition-colors">{authorNames[0]}</a>
              <span class="text-[#555]"> · <time datetime={pubISO}>{pubFormatted}</time>{article.read_time_minutes && ` · ${article.read_time_minutes} min read`}</span>
            </div>
          </div>
          {/* Share buttons */}
          <div class="flex items-center gap-2">
            <a href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(articleUrl)}&title=${encodeURIComponent(article.title)}&summary=${encodeURIComponent(linkedinSummary)}&source=Product+Impact`} target="_blank" rel="noopener" title="Share on LinkedIn"
              class="w-8 h-8 rounded-lg bg-[#111] border border-[#222] flex items-center justify-center text-[#666] hover:text-[#0077B5] hover:border-[#0077B5]/30 transition-all">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
            <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(twitterShareText)}`} target="_blank" rel="noopener" title="Share on X"
              class="w-8 h-8 rounded-lg bg-[#111] border border-[#222] flex items-center justify-center text-[#666] hover:text-white hover:border-[#444] transition-all">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
            <button id="copy-link-btn" title="Copy link"
              class="w-8 h-8 rounded-lg bg-[#111] border border-[#222] flex items-center justify-center text-[#666] hover:text-[#ff6b4a] hover:border-[#ff6b4a]/30 transition-all">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
            </button>
          </div>
        </div>

        {/* Hero image (if exists) */}
        {article.hero_image_url && (
          <figure class="mb-8 -mx-4 md:mx-0 relative">
            <img
              src={article.hero_image_url}
              alt={article.hero_image_alt ?? article.title}
              width="1200" height="628" loading="eager" fetchpriority="high" decoding="sync"
              class="w-full rounded-none md:rounded-xl aspect-[1.91/1] object-cover"
            />
            <button id="hero-fav-btn" type="button" title="Favourite this article"
              class="absolute top-4 right-4 md:top-5 md:right-5 w-10 h-10 rounded-full bg-black/40 backdrop-blur-sm border border-white/10 flex items-center justify-center text-white/60 hover:text-[#ff6b4a] hover:border-[#ff6b4a]/30 transition-all group">
              <svg class="w-5 h-5 transition-transform group-hover:scale-110" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
            </button>
            {article.hero_image_credit && (
              <figcaption class="text-[11px] text-[#555] mt-2 px-4 md:px-0">
                Photo: {article.hero_image_credit}
              </figcaption>
            )}
          </figure>
        )}

        {/* ── Overview bullets — Particle's signature pattern ── */}
        {bullets.length > 0 && (
          <div class="mb-8 p-5 rounded-xl border border-[#1a1a1a] bg-[#0d0d0d]">
            <div class="text-[10px] font-bold uppercase tracking-[0.1em] text-[#ff6b4a] mb-3">
              Overview
            </div>
            <ul class="space-y-3">
              {bullets.map((b) => (
                <li class="flex gap-2.5 text-[15px] leading-[1.65] text-[#ddd]">
                  <span class="text-[#ff6b4a] mt-1.5 flex-shrink-0 text-[8px]">●</span>
                  <span>{b}</span>
                </li>
              ))}
            </ul>
          </div>
        )}

        {/* ── Article body ── */}
        <div class="article-prose" set:html={cleanedHtml}></div>

        {/* ── Heart reactions ── */}
        <div class="mt-12 pt-8 border-t border-[#1a1a1a]"
          data-article-id={article.id}
          data-sb-url={import.meta.env.PUBLIC_SUPABASE_URL}
          data-sb-key={import.meta.env.PUBLIC_SUPABASE_ANON_KEY}
          id="engagement-container">
          <div class="flex items-center justify-between mb-4">
            <p class="text-[14px] font-bold text-white">How helpful was this article?</p>
            <span id="heart-count" class="text-[14px] font-semibold text-[#ff6b4a]"></span>
          </div>
          <div class="flex gap-3">
            <button type="button" data-hearts="1"
              class="heart-btn flex items-center gap-2.5 px-6 py-3.5 rounded-xl bg-[#1a1a1a] border border-[#2a2a2a] text-white hover:border-[#ff6b4a]/40 hover:bg-[#ff6b4a]/10 transition-all group">
              <span class="text-[20px] group-hover:scale-110 transition-transform">❤️</span>
              <span class="text-[14px] font-semibold">Good</span>
            </button>
            <button type="button" data-hearts="2"
              class="heart-btn flex items-center gap-2.5 px-6 py-3.5 rounded-xl bg-[#1a1a1a] border border-[#2a2a2a] text-white hover:border-[#ff6b4a]/40 hover:bg-[#ff6b4a]/10 transition-all group">
              <span class="text-[20px] group-hover:scale-110 transition-transform">❤️❤️</span>
              <span class="text-[14px] font-semibold">Great</span>
            </button>
            <button type="button" data-hearts="3"
              class="heart-btn flex items-center gap-2.5 px-6 py-3.5 rounded-xl bg-[#1a1a1a] border border-[#2a2a2a] text-white hover:border-[#ff6b4a]/40 hover:bg-[#ff6b4a]/10 transition-all group">
              <span class="text-[20px] group-hover:scale-110 transition-transform">❤️❤️❤️</span>
              <span class="text-[14px] font-semibold">Must read</span>
            </button>
          </div>
        </div>

        {/* ── Social sharing — large buttons ── */}
        <div class="mt-10 pt-8 border-t border-[#1a1a1a]">
          <p class="text-[11px] font-bold uppercase tracking-wider text-[#555] mb-4">Share this article</p>
          <div class="flex flex-wrap gap-3">
            <a href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(articleUrl)}&title=${encodeURIComponent(article.title)}&summary=${encodeURIComponent(linkedinSummary)}&source=Product+Impact`} target="_blank" rel="noopener"
              class="flex items-center gap-2.5 px-5 py-3 rounded-xl bg-[#0A66C2]/10 border border-[#0A66C2]/20 text-[#0A66C2] hover:bg-[#0A66C2]/20 transition-colors">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              <span class="text-[14px] font-semibold">LinkedIn</span>
            </a>
            <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(twitterShareText)}`} target="_blank" rel="noopener"
              class="flex items-center gap-2.5 px-5 py-3 rounded-xl bg-white/5 border border-white/10 text-white hover:bg-white/10 transition-colors">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              <span class="text-[14px] font-semibold">X / Twitter</span>
            </a>
            <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(articleUrl)}`} target="_blank" rel="noopener"
              class="flex items-center gap-2.5 px-5 py-3 rounded-xl bg-[#1877F2]/10 border border-[#1877F2]/20 text-[#1877F2] hover:bg-[#1877F2]/20 transition-colors">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              <span class="text-[14px] font-semibold">Facebook</span>
            </a>
            <a href={`mailto:?subject=${encodeURIComponent(article.title)}&body=${encodeURIComponent(`${article.title}\n\n${article.meta_description ?? ''}\n\n${articleUrl}`)}`}
              class="flex items-center gap-2.5 px-5 py-3 rounded-xl bg-[#ff6b4a]/10 border border-[#ff6b4a]/20 text-[#ff6b4a] hover:bg-[#ff6b4a]/20 transition-colors">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><path d="M22 6l-10 7L2 6"/></svg>
              <span class="text-[14px] font-semibold">Email</span>
            </a>
            <button id="copy-link-bottom" class="flex items-center gap-2.5 px-5 py-3 rounded-xl bg-[#111] border border-[#222] text-[#888] hover:text-white hover:border-[#444] transition-colors">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
              <span class="text-[14px] font-semibold">Copy Link</span>
            </button>
          </div>
        </div>

        {/* ── Author card ── */}
        <div class="mt-10 pt-8 border-t border-[#1a1a1a]">
          <div class="flex items-start gap-4">
            <div class="w-14 h-14 rounded-full bg-[#1a1a1a] flex items-center justify-center flex-shrink-0">
              <span class="text-[18px] font-bold text-[#ff6b4a]">
                {authorNames[0]?.charAt(0) ?? "A"}
              </span>
            </div>
            <div>
              <a href={`/people/${article.author_slugs?.[0] ?? "arpy-dragffy"}/`} class="text-[16px] font-bold text-white hover:text-[#ff6b4a] transition-colors">
                {authorNames[0]}
              </a>
              {article.byline_role && (
                <p class="text-[13px] text-[#777] mt-0.5">{article.byline_role}</p>
              )}
              <a href={`/people/${article.author_slugs?.[0] ?? "arpy-dragffy"}/`} class="text-[12px] text-[#ff6b4a] mt-2 inline-block hover:text-white transition-colors">
                View all articles →
              </a>
            </div>
          </div>
        </div>

        {/* Soft CTA */}
        <p class="mt-8 text-[12px] text-[#555] leading-relaxed">
          Hosted by <a href="/people/arpy-dragffy/" class="text-[#ff6b4a]">Arpy Dragffy</a> and <a href="/people/brittany-hobbs/" class="text-[#ff6b4a]">Brittany Hobbs</a>.
          Arpy runs <a href="https://ph1.ca?utm_source=productimpactpod&utm_medium=article-footer" target="_blank" rel="noopener" class="text-[#ff6b4a]">PH1 Research</a>, a product adoption research firm,
          and leads <a href="https://aivalueacceleration.com?utm_source=productimpactpod&utm_medium=article-footer" target="_blank" rel="noopener" class="text-[#ff6b4a]">AI Value Acceleration</a>, enterprise AI consulting.
        </p>

        {/* Newsletter */}
        <div class="mt-10 pt-8 border-t border-[#1a1a1a] text-center">
          <p class="text-[13px] text-[#666] mb-3">Get AI product impact news weekly</p>
          <a href="https://productimpactpod.substack.com" target="_blank" rel="noopener"
            class="inline-flex items-center px-5 py-2 rounded-lg bg-[#ff6b4a] hover:bg-[#ff8566] text-white text-[13px] font-semibold transition-colors">
            Subscribe
          </a>
        </div>
      </div>

      {/* ════ RIGHT COLUMN: sidebar (desktop) ════ */}
      <aside class="hidden lg:block">
        <div class="sticky top-20 space-y-6">

          {/* Related articles — first */}
          {related.length > 0 && (
            <div>
              <div class="flex items-baseline gap-2 mb-3 pb-2 border-b border-[#181818]">
                <span class="text-[14px] font-bold text-white">Related</span>
                <span class="text-[13px] font-bold text-[#ff6b4a]">{related.length}</span>
              </div>
              {related.map((r) => (
                <StoryCard article={r} size="compact" />
              ))}
            </div>
          )}

          {/* Substack subscribe — below related */}
          <div class="p-5 rounded-xl border border-[#ff6b4a]/10 bg-[#ff6b4a]/[0.03]">
            <h3 class="text-[13px] font-bold text-white mb-1.5">Product Impact Newsletter</h3>
            <p class="text-[12px] text-[#888] mb-3 leading-relaxed">AI product strategy delivered weekly. Free.</p>
            <form id="sidebar-substack-form" class="flex items-stretch gap-0">
              <input type="email" id="sidebar-substack-email" placeholder="Your email..." required
                class="flex-1 px-3 py-2 bg-[#111] border border-[#222] rounded-l-lg text-[12px] text-white placeholder:text-[#555] focus:outline-none focus:border-[#ff6b4a] transition-colors" />
              <button type="submit" class="px-3 py-2 bg-[#ff6b4a] text-white text-[12px] font-bold rounded-r-lg hover:bg-[#ff8566] transition-colors shrink-0">Go</button>
            </form>
          </div>

          {/* Back to news */}
          <a href="/news" class="text-[12px] text-[#555] hover:text-[#ff6b4a] transition-colors block">
            ← All articles
          </a>
        </div>
      </aside>
    </div>

    {/* ── Latest podcast episodes ── */}
    {latestEpisodes.length > 0 && (
      <section class="mt-12 pt-8 border-t border-[#1a1a1a]">
        <div class="flex items-center justify-between mb-5">
          <h2 class="text-[18px] font-extrabold text-white">Latest Episodes <span class="text-[#ff6b4a]">&#8250;</span></h2>
          <a href="/podcast/" class="text-[12px] text-[#666] hover:text-white transition-colors">All episodes</a>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
          {latestEpisodes.map((ep) => {
            const epLabel = ep.episodeNumber ? `EP ${ep.episodeNumber}` : "";
            const date = ep.pubDate ?? "";
            return (
              <a href={ep.link || "/podcast/"} target="_blank" rel="noopener" class="group block rounded-xl overflow-hidden border border-[#161616] hover:border-[#282828] transition-all bg-[#0c0c0c]">
                <div class="relative aspect-square overflow-hidden">
                  {ep.imageUrl ? (
                    <img src={ep.imageUrl} alt={ep.title} class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500" loading="lazy" />
                  ) : (
                    <div class="w-full h-full bg-[#111] flex items-center justify-center"><span class="text-[28px]">🎙</span></div>
                  )}
                  <div class="absolute inset-0 bg-black/30 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                    <div class="w-10 h-10 rounded-full bg-white/90 flex items-center justify-center shadow-xl">
                      <svg class="w-4 h-4 text-black ml-0.5" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                    </div>
                  </div>
                  {epLabel && <div class="absolute bottom-1.5 left-1.5 text-[9px] font-bold text-white bg-black/60 backdrop-blur-sm px-1.5 py-0.5 rounded">{epLabel}</div>}
                </div>
                <div class="p-2.5">
                  <h3 class="text-[12px] font-semibold text-[#ccc] group-hover:text-white leading-snug line-clamp-2 mb-1 transition-colors">{ep.title}</h3>
                  <div class="text-[10px] text-[#555]">{date}</div>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    )}

    {/* ── Mobile related articles (below article body) ── */}
    {related.length > 0 && (
      <section class="lg:hidden mt-12 pt-8 border-t border-[#1a1a1a]">
        <div class="flex items-baseline gap-2 mb-4">
          <h2 class="text-[15px] font-bold text-white">Related</h2>
          <span class="text-[13px] font-bold text-[#ff6b4a]">{related.length}</span>
        </div>
        <div class="space-y-1">
          {related.map((r) => (
            <StoryCard article={r} size="compact" />
          ))}
        </div>
      </section>
    )}

  </main>

  <Footer />
</BaseLayout>

<script is:inline>
(function() {
  // Copy link button
  var copyBtn = document.getElementById('copy-link-btn');
  if (copyBtn) {
    copyBtn.addEventListener('click', function() {
      navigator.clipboard.writeText(window.location.href).then(function() {
        copyBtn.innerHTML = '<svg class="w-3.5 h-3.5 text-[#ff6b4a]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>';
        setTimeout(function() {
          copyBtn.innerHTML = '<svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>';
        }, 2000);
      });
    });
  }
  // Bottom copy-link button
  var copyBtnBottom = document.getElementById('copy-link-bottom');
  if (copyBtnBottom) {
    copyBtnBottom.addEventListener('click', function() {
      navigator.clipboard.writeText(window.location.href).then(function() {
        var span = copyBtnBottom.querySelector('span');
        if (span) { span.textContent = 'Copied!'; setTimeout(function() { span.textContent = 'Copy Link'; }, 2000); }
      });
    });
  }
  // Sidebar Substack form
  var form = document.getElementById('sidebar-substack-form');
  var email = document.getElementById('sidebar-substack-email');
  if (form && email) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var val = email.value.trim();
      if (val) { window.open('https://productimpactpod.substack.com/subscribe?email=' + encodeURIComponent(val), '_blank'); email.value = ''; }
    });
  }
})();
</script>

<script is:inline>
(function() {
  var ec = document.getElementById('engagement-container');
  if (!ec) return;
  var articleId = ec.getAttribute('data-article-id');
  var sbUrl = ec.getAttribute('data-sb-url');
  var sbKey = ec.getAttribute('data-sb-key');
  if (!articleId || !sbUrl || !sbKey) return;

  var headers = { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + sbKey, 'apikey': sbKey };

  function rpc(fn, params) {
    return fetch(sbUrl + '/rest/v1/rpc/' + fn, {
      method: 'POST', headers: headers, body: JSON.stringify(params)
    });
  }

  // Track unique view
  var viewKey = 'pi_viewed_' + articleId;
  if (!localStorage.getItem(viewKey)) {
    rpc('increment_view', { p_article_id: articleId });
    localStorage.setItem(viewKey, '1');
  }

  // Track shares — attach to all share links in the article
  var shareKey = 'pi_shared_' + articleId;
  document.querySelectorAll('a[target="_blank"][href*="linkedin.com/share"], a[target="_blank"][href*="twitter.com/intent"], a[target="_blank"][href*="facebook.com/sharer"]').forEach(function(link) {
    link.addEventListener('click', function() {
      if (!localStorage.getItem(shareKey)) {
        rpc('increment_share', { p_article_id: articleId });
        localStorage.setItem(shareKey, '1');
      }
    });
  });

  // Heart buttons
  var heartKey = 'pi_hearted_' + articleId;
  var heartCount = document.getElementById('heart-count');
  var hearted = localStorage.getItem(heartKey);

  // Load current heart count
  fetch(sbUrl + '/rest/v1/article_engagement?article_id=eq.' + articleId + '&select=hearts', { headers: headers })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data && data[0] && heartCount) {
        heartCount.textContent = data[0].hearts > 0 ? data[0].hearts + ' ❤️' : '';
      }
    }).catch(function() {});

  document.querySelectorAll('.heart-btn').forEach(function(btn) {
    if (hearted) {
      btn.style.opacity = '0.5';
      btn.style.pointerEvents = 'none';
    }
    btn.addEventListener('click', function() {
      if (localStorage.getItem(heartKey)) return;
      var amount = parseInt(btn.getAttribute('data-hearts') || '1');
      rpc('add_hearts', { p_article_id: articleId, p_amount: amount });
      localStorage.setItem(heartKey, String(amount));

      // Visual feedback
      btn.style.borderColor = '#ff6b4a';
      btn.style.background = 'rgba(255,107,74,0.1)';
      btn.style.color = '#ff6b4a';
      document.querySelectorAll('.heart-btn').forEach(function(b) {
        if (b !== btn) { b.style.opacity = '0.3'; b.style.pointerEvents = 'none'; }
      });
      btn.style.pointerEvents = 'none';

      if (heartCount) {
        var cur = parseInt(heartCount.textContent) || 0;
        heartCount.textContent = (cur + amount) + ' ❤️';
      }
    });
  });

  // Hero fav button — same as 1 heart
  var heroFav = document.getElementById('hero-fav-btn');
  if (heroFav) {
    if (hearted) {
      heroFav.querySelector('svg').setAttribute('fill', '#ff6b4a');
      heroFav.querySelector('svg').setAttribute('stroke', '#ff6b4a');
      heroFav.classList.add('text-[#ff6b4a]');
    }
    heroFav.addEventListener('click', function() {
      if (localStorage.getItem(heartKey)) return;
      rpc('add_hearts', { p_article_id: articleId, p_amount: 1 });
      localStorage.setItem(heartKey, '1');
      heroFav.querySelector('svg').setAttribute('fill', '#ff6b4a');
      heroFav.querySelector('svg').setAttribute('stroke', '#ff6b4a');
      heroFav.classList.add('text-[#ff6b4a]');
      document.querySelectorAll('.heart-btn').forEach(function(b) {
        b.style.opacity = '0.3'; b.style.pointerEvents = 'none';
      });
      if (heartCount) {
        var cur = parseInt(heartCount.textContent) || 0;
        heartCount.textContent = (cur + 1) + ' ❤️';
      }
    });
  }
})();
</script>
