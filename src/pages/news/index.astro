---
// /news — canonical index of all editorial articles.
// Server-side rendered list from the articles table.

import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";
import Footer from "@components/Footer.astro";
import {
  getAllArticles,
  formatLabel,
  themeLabel,
} from "@lib/supabase";

const articles = await getAllArticles();
const siteUrl = "https://productimpactpod.com";

const themeGradients: Record<string, string> = {
  "ai-product-strategy": "from-[#ff6b4a] to-[#8a3a28]",
  "agents-agentic-systems": "from-[#9b7bff] to-[#4a3a80]",
  "ux-experience-design-for-ai": "from-[#4ab8c9] to-[#1f5a66]",
  "adoption-organizational-change": "from-[#f5a623] to-[#7a5310]",
  "evaluation-benchmarking": "from-[#6bbf71] to-[#2d5a30]",
  "go-to-market-distribution": "from-[#ff8566] to-[#8a3a28]",
  "data-semantics-knowledge-foundations": "from-[#5ba3cc] to-[#1f4a66]",
  "governance-risk-trust": "from-[#c96bff] to-[#5a2a80]",
};

const collectionPageJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Product Impact News",
  description:
    "AI product impact — news, releases, and case studies about the products transforming how we work and industries.",
  url: `${siteUrl}/news`,
  isPartOf: {
    "@type": "WebSite",
    name: "Product Impact",
    url: siteUrl,
  },
  mainEntity: {
    "@type": "ItemList",
    itemListElement: articles.map((a, i) => ({
      "@type": "ListItem",
      position: i + 1,
      url: `${siteUrl}/news/${a.slug}`,
      name: a.title,
    })),
  },
};
---

<BaseLayout
  title="News | Product Impact"
  description="AI product impact — news, releases, and case studies about the products transforming how we work and industries."
  canonicalUrl={`${siteUrl}/news`}
  jsonLd={collectionPageJsonLd}
>
  <Nav />

  <main class="container-wide py-16">
    {/* Page header */}
    <header class="mb-12">
      <h1 class="text-5xl md:text-7xl font-extrabold uppercase tracking-tight text-white mb-4">
        News
      </h1>
      <p class="text-lg text-[#d4d4d4] max-w-2xl">
        AI product impact — news, releases, and case studies about the products transforming how we work.
      </p>
    </header>

    {/* Filter tabs — static for now, wire up client-side filtering in v2 */}
    <div class="flex flex-wrap gap-2 mb-12 border-b border-[#2a2a2a] pb-6">
      <a
        href="/news"
        class="px-4 py-2 rounded-full text-sm font-semibold bg-background-card text-white border border-accent"
      >
        All
      </a>
      {[
        "news-brief",
        "news-analysis",
        "release-note",
        "feature",
        "interview",
        "case-study",
        "opinion",
        "explainer",
        "product-review",
        "research-brief",
      ].map((fmt) => (
        <a
          href={`/news/format/${fmt}`}
          class="px-4 py-2 rounded-full text-sm font-semibold text-[#d4d4d4] hover:text-white hover:bg-background-card transition-colors"
        >
          {formatLabel(fmt as any)}
        </a>
      ))}
    </div>

    {/* Articles grid */}
    {articles.length === 0 ? (
      <div class="text-center py-24">
        <p class="text-xl text-[#a0a0a0]">No articles published yet.</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {articles.map((article) => {
          const firstTheme = article.themes?.[0] ?? "ai-product-strategy";
          const gradient =
            themeGradients[firstTheme] ??
            themeGradients["ai-product-strategy"];
          const date = new Date(article.publish_date).toLocaleDateString(
            "en-US",
            { month: "short", day: "numeric", year: "numeric" },
          );
          return (
            <a
              href={`/news/${article.slug}`}
              class="group block bg-background-card rounded-xl overflow-hidden hover:bg-background-hover transition-colors"
            >
              {article.hero_image_url ? (
                <img
                  src={article.hero_image_url}
                  alt={article.hero_image_alt ?? article.title}
                  loading="lazy"
                  class="w-full aspect-video object-cover"
                />
              ) : (
                <div
                  class={`w-full aspect-video bg-gradient-to-br ${gradient} flex items-center justify-center p-6`}
                >
                  <div class="text-[10px] uppercase tracking-widest text-white/80 font-semibold">
                    Product Impact
                  </div>
                </div>
              )}
              <div class="p-6">
                <div class="flex flex-wrap items-center gap-2 mb-3">
                  <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider bg-accent text-black">
                    {formatLabel(article.format)}
                  </span>
                  {article.themes?.slice(0, 2).map((t) => (
                    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold uppercase tracking-wider border border-[#3a3a3a] text-[#a0a0a0]">
                      {themeLabel(t)}
                    </span>
                  ))}
                </div>
                <h2 class="text-xl font-bold text-white mb-2 leading-snug group-hover:text-accent transition-colors line-clamp-2">
                  {article.title}
                </h2>
                {article.subtitle && (
                  <p class="text-sm text-[#d4d4d4] line-clamp-3 leading-relaxed">
                    {article.subtitle}
                  </p>
                )}
                <div class="text-xs text-[#707070] mt-4 flex items-center gap-2">
                  <time datetime={article.publish_date}>{date}</time>
                  {article.read_time_minutes && (
                    <>
                      <span>·</span>
                      <span>{article.read_time_minutes} min read</span>
                    </>
                  )}
                </div>
              </div>
            </a>
          );
        })}
      </div>
    )}
  </main>

  <Footer />
</BaseLayout>
