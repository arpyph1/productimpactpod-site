---
// /news — page 1 of the paginated news index.
// Later pages live at /news/page/2, /news/page/3 etc.
// Split from /news/page/[page] to avoid URL collision with /news/[year]
// date archives.

import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";
import Footer from "@components/Footer.astro";
import ArticleCard from "@components/ArticleCard.astro";
import Pagination from "@components/Pagination.astro";
import { getAllArticles, formatLabel } from "@lib/supabase";

const PAGE_SIZE = 24;
const articles = await getAllArticles();
const pageArticles = articles.slice(0, PAGE_SIZE);
const lastPage = Math.max(1, Math.ceil(articles.length / PAGE_SIZE));
const hasNext = articles.length > PAGE_SIZE;

const siteUrl = "https://productimpactpod.com";
const canonicalUrl = `${siteUrl}/news`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "News | Product Impact",
  description:
    "AI product impact — news, releases, and case studies about the products transforming how we work and industries.",
  url: canonicalUrl,
  isPartOf: { "@id": `${siteUrl}/#website` },
  mainEntity: {
    "@type": "ItemList",
    itemListElement: pageArticles.map((a, i) => ({
      "@type": "ListItem",
      position: i + 1,
      url: `${siteUrl}/news/${a.slug}`,
      name: a.title,
    })),
  },
};
---

<BaseLayout
  title="News | Product Impact"
  description="AI product impact — news, releases, and case studies about the products transforming how we work and industries."
  canonicalUrl={canonicalUrl}
  jsonLd={jsonLd}
>
  <Nav />

  <main class="container-wide py-16">
    <header class="mb-12">
      <h1 class="text-5xl md:text-7xl font-extrabold uppercase tracking-tight text-white mb-4">
        News
      </h1>
      <p class="text-lg text-[#d4d4d4] max-w-2xl">
        AI product impact — news, releases, and case studies about the products transforming how we work.
      </p>
    </header>

    {/* Format filter tabs */}
    <div class="flex flex-wrap gap-2 mb-12 border-b border-[#2a2a2a] pb-6">
      <a
        href="/news"
        class="px-4 py-2 rounded-full text-sm font-semibold bg-background-card text-white border border-accent"
        aria-current="page"
      >
        All
      </a>
      {([
        "news-brief", "news-analysis", "release-note", "feature",
        "interview", "case-study", "opinion", "explainer",
        "product-review", "research-brief",
      ] as const).map((fmt) => (
        <a
          href={`/news/format/${fmt}`}
          class="px-4 py-2 rounded-full text-sm font-semibold text-[#d4d4d4] hover:text-white hover:bg-background-card transition-colors"
        >
          {formatLabel(fmt)}
        </a>
      ))}
    </div>

    {pageArticles.length === 0 ? (
      <div class="text-center py-24">
        <p class="text-xl text-[#a0a0a0]">No articles published yet.</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {pageArticles.map((article) => <ArticleCard article={article} />)}
      </div>
    )}

    <Pagination
      currentPage={1}
      lastPage={lastPage}
      prevUrl={null}
      nextUrl={hasNext ? "/news/page/2" : null}
    />
  </main>

  <Footer />
</BaseLayout>
