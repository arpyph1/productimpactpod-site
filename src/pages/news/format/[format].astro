---
import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";
import Footer from "@components/Footer.astro";
import EntityHeadline from "@components/EntityHeadline.astro";
import { getAllArticles, formatLabel, authorDisplayName, type ArticleFormat } from "@lib/supabase";

const validFormats: ArticleFormat[] = [
  "news-brief", "news-analysis", "release-note", "feature", "interview",
  "case-study", "opinion", "explainer", "product-review", "research-brief",
];

export async function getStaticPaths() {
  return [
    "news-brief", "news-analysis", "release-note", "feature", "interview",
    "case-study", "opinion", "explainer", "product-review", "research-brief",
  ].map((f) => ({ params: { format: f } }));
}

const { format } = Astro.params;
const allArticles = await getAllArticles();
const articles = allArticles.filter((a) => a.format === format);
const siteUrl = "https://productimpactpod.com";
const label = formatLabel(format as ArticleFormat);

const formats: ArticleFormat[] = ["news-analysis", "feature", "interview", "case-study", "release-note", "opinion", "explainer"];

function timeAgo(d: string): string {
  const days = Math.floor((Date.now() - new Date(d).getTime()) / 86400000);
  if (days === 0) return "Today";
  if (days === 1) return "1d ago";
  if (days < 7) return `${days}d ago`;
  if (days < 30) return `${Math.floor(days / 7)}w ago`;
  return `${Math.floor(days / 30)}mo ago`;
}
---

<BaseLayout
  title={`${label} | Product Impact News`}
  description={`${label} articles — AI product impact news, releases, and case studies.`}
  canonicalUrl={`${siteUrl}/news/format/${format}`}
>
  <Nav />

  <main class="max-w-[900px] mx-auto px-4 md:px-6 py-8">
    <header class="mb-6">
      <nav class="text-[11px] text-[#555] mb-3 flex items-center gap-1.5">
        <a href="/" class="hover:text-white">Home</a>
        <span class="text-[#333]">›</span>
        <a href="/news/" class="hover:text-white">News</a>
        <span class="text-[#333]">›</span>
        <span class="text-[#888]">{label}</span>
      </nav>
      <div class="flex items-baseline gap-2 mb-1">
        <h1 class="text-[28px] md:text-[36px] font-extrabold text-white tracking-tight">{label}</h1>
        <span class="text-[16px] font-bold text-[#ff6b4a]">{articles.length}</span>
      </div>
    </header>

    {/* Filter tabs */}
    <div class="flex flex-wrap gap-1.5 mb-8 pb-5 border-b border-[#141414]">
      <a href="/news/" class="px-3 py-1.5 rounded-md text-[11px] font-medium text-[#777] hover:text-white hover:bg-[#1a1a1a] transition-colors">All</a>
      {formats.map((fmt) => (
        <a href={`/news/format/${fmt}/`} class={`px-3 py-1.5 rounded-md text-[11px] font-semibold ${fmt === format ? 'bg-[#ff6b4a] text-white' : 'text-[#777] hover:text-white hover:bg-[#1a1a1a] transition-colors'}`}>
          {formatLabel(fmt)}
        </a>
      ))}
    </div>

    {articles.length === 0 ? (
      <p class="text-[#666] text-center py-16">No {label.toLowerCase()} articles published yet.</p>
    ) : (
      <div class="divide-y divide-[#161616]">
        {articles.map((a) => {
          const entities = [...(a.people ?? []), ...(a.organizations ?? []), ...(a.products ?? [])];
          const author = authorDisplayName(a.author_slugs?.[0] ?? "");
          const time = timeAgo(a.publish_date);
          return (
            <a href={`/news/${a.slug}/`} class="group flex gap-4 py-4 items-start">
              <div class="w-[72px] h-[72px] md:w-[88px] md:h-[88px] rounded-lg overflow-hidden flex-shrink-0 bg-[#111]">
                {a.hero_image_url ? (
                  <img src={a.hero_image_url} alt="" class="w-full h-full object-cover group-hover:scale-[1.05] transition-transform duration-500" loading="lazy" />
                ) : (
                  <div class="w-full h-full bg-gradient-to-br from-[#1a0e08] to-[#111]"></div>
                )}
              </div>
              <div class="flex-1 min-w-0 pt-0.5">
                <EntityHeadline title={a.title} entities={entities} tag="h3"
                  class="text-[15px] md:text-[17px] font-bold text-[#e5e5e5] leading-[1.3] group-hover:text-white transition-colors inline" />
                {a.subtitle && <span class="text-[14px] md:text-[16px] text-[#666]"> / {a.subtitle}</span>}
                <div class="flex items-center gap-2 mt-1.5 text-[11px]">
                  <span class="font-semibold text-[#ff6b4a] uppercase tracking-wide">{author}</span>
                  <span class="text-[#333]">|</span>
                  <span class="text-[#555]">{time}</span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    )}
  </main>

  <Footer />
</BaseLayout>
