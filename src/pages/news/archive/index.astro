---
// /news/archive — directory of date archives.
// Year counts + most-recent months. Google News weights regularly-updated
// archive pages as a discovery signal.

import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";
import Footer from "@components/Footer.astro";
import { getAllArticles } from "@lib/supabase";

const articles = await getAllArticles();
const siteUrl = "https://productimpactpod.com";

// Aggregate articles by year and by year-month
type YearBucket = { year: number; count: number; months: Map<string, number> };
const byYear = new Map<number, YearBucket>();

for (const a of articles) {
  const date = new Date(a.publish_date);
  if (isNaN(date.getTime())) continue;
  const year = date.getUTCFullYear();
  const monthIso = `${year}-${String(date.getUTCMonth() + 1).padStart(2, "0")}`;

  let bucket = byYear.get(year);
  if (!bucket) {
    bucket = { year, count: 0, months: new Map() };
    byYear.set(year, bucket);
  }
  bucket.count++;
  bucket.months.set(monthIso, (bucket.months.get(monthIso) ?? 0) + 1);
}

const sortedYears = [...byYear.values()].sort((a, b) => b.year - a.year);

const monthName = (iso: string) => {
  const [y, m] = iso.split("-");
  const d = new Date(Date.UTC(+y, +m - 1, 1));
  return d.toLocaleString("en-US", { month: "long", timeZone: "UTC" });
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "News Archive | Product Impact",
  url: `${siteUrl}/news/archive`,
  description: "Browse the Product Impact news archive by year and month.",
  isPartOf: { "@id": `${siteUrl}/#website` },
};
---

<BaseLayout
  title="News Archive | Product Impact"
  description="Browse the Product Impact news archive by year and month — every article organised by publish date."
  canonicalUrl={`${siteUrl}/news/archive`}
  jsonLd={jsonLd}
>
  <Nav />

  <main class="container-wide py-16 max-w-4xl mx-auto">
    <header class="mb-12">
      <div class="mb-3">
        <a href="/news" class="text-sm text-[#a0a0a0] hover:text-white">← News</a>
      </div>
      <h1 class="text-5xl md:text-7xl font-extrabold uppercase tracking-tight text-white mb-4">
        Archive
      </h1>
      <p class="text-lg text-[#d4d4d4]">
        {articles.length} articles across {sortedYears.length} year{sortedYears.length !== 1 ? "s" : ""}.
      </p>
    </header>

    {sortedYears.length === 0 ? (
      <div class="text-center py-24">
        <p class="text-xl text-[#a0a0a0]">No articles in the archive yet.</p>
      </div>
    ) : (
      <div class="space-y-10">
        {sortedYears.map((y) => {
          const sortedMonths = [...y.months.entries()].sort(([a], [b]) => b.localeCompare(a));
          return (
            <section>
              <div class="flex items-baseline justify-between mb-4 pb-3 border-b border-[#2a2a2a]">
                <a
                  href={`/news/${y.year}`}
                  class="text-4xl font-extrabold text-white hover:text-accent transition-colors"
                >
                  {y.year}
                </a>
                <span class="text-sm text-[#707070]">
                  {y.count} article{y.count !== 1 ? "s" : ""}
                </span>
              </div>
              <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-2">
                {sortedMonths.map(([monthIso, count]) => (
                  <a
                    href={`/news/${monthIso.replace("-", "/")}`}
                    class="group flex items-baseline justify-between gap-3 px-4 py-3 rounded-lg bg-background-card hover:bg-background-hover transition-colors"
                  >
                    <span class="text-sm font-semibold text-[#d4d4d4] group-hover:text-accent transition-colors">
                      {monthName(monthIso)}
                    </span>
                    <span class="text-xs text-[#707070]">{count}</span>
                  </a>
                ))}
              </div>
            </section>
          );
        })}
      </div>
    )}
  </main>

  <Footer />
</BaseLayout>
