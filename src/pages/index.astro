---
// Homepage — Podcast.tsx-style layout ported from Lovable.
// Section order (matches DEFAULT_ORDER in Lovable/Podcast.tsx):
//   1. Hero (Shorts staircase + platform pills + headline)
//   2. Episodes (live podcast RSS, cover-art grid)
//   3. Hosts (large 9:16 vertical portraits)
//   4. Newsletter (Substack RSS — latest editions)
//   5. Subscribe (listen-on-X CTAs)

import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";
import Footer from "@components/Footer.astro";
import Hero from "@components/Hero.astro";
import Episodes from "@components/Episodes.astro";
import Hosts from "@components/Hosts.astro";
import Newsletter from "@components/Newsletter.astro";

const siteUrl = "https://productimpactpod.com";

const homepageJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${siteUrl}/#webpage`,
  url: `${siteUrl}/`,
  name: "Product Impact — AI product news, releases, and case studies",
  description:
    "AI product impact — news, releases, and case studies about the products transforming how we work and industries.",
  isPartOf: { "@id": `${siteUrl}/#website` },
  about: { "@id": `${siteUrl}/#organization` },
  inLanguage: "en-US",
};
---

<BaseLayout
  title="Product Impact — AI product news, releases, and case studies"
  description="AI product impact — news, releases, and case studies about the products transforming how we work and industries."
  canonicalUrl={`${siteUrl}/`}
  jsonLd={homepageJsonLd}
>
  <Nav />

  <main class="min-h-screen bg-background">
    {/* ── 1. HERO ────────────────────────────────────────────────── */}
    <Hero />

    {/* ── 2. EPISODES (live podcast RSS) ───────────────────────── */}
    <Episodes title="Latest Episodes" limit={8} />

    {/* ── 3. HOSTS (large vertical portraits) ──────────────────── */}
    <Hosts />

    {/* ── 4. NEWSLETTER (Substack RSS) ─────────────────────────── */}
    <Newsletter title="From the Newsletter" />

    {/* ── 5. SUBSCRIBE CTA ─────────────────────────────────────── */}
    <section id="subscribe" class="bg-background" aria-label="Subscribe">
      <div class="container-wide py-16">
        <div class="studio-card p-8 md:p-14 text-center bg-gradient-to-br from-primary/5 via-card to-card">
          <h2
            class="font-display font-extrabold uppercase leading-none tracking-tight text-foreground mb-4"
            style="font-size: clamp(1.5rem, 3.5vw, 2.8rem); letter-spacing: -0.02em;"
          >
            Listen on your platform
          </h2>
          <p class="text-muted-foreground mb-8 max-w-lg mx-auto">
            New episodes weekly. Subscribe wherever you listen to podcasts.
          </p>
          <div class="flex flex-wrap items-center justify-center gap-3">
            {[
              { label: "Spotify",         url: "https://open.spotify.com/show/productimpactpod",   color: "#1DB954" },
              { label: "Apple Podcasts",  url: "https://podcasts.apple.com/productimpactpod",      color: "#B150E2" },
              { label: "YouTube",         url: "https://youtube.com/@productimpactpod",            color: "#FF0000" },
              { label: "Substack",        url: "https://productimpactpod.substack.com",            color: "#FF6719" },
            ].map((p) => (
              <a
                href={p.url}
                target="_blank"
                rel="noopener"
                class="flex items-center gap-3 px-6 py-3 rounded-full border border-border bg-card text-foreground font-medium hover:border-foreground transition-all"
              >
                <span class="w-3 h-3 rounded-full flex-shrink-0" style={`background: ${p.color};`}></span>
                {p.label}
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <div class="py-6"></div>
  </main>

  <Footer />
</BaseLayout>
