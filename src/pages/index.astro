{/* ── Carousel + Substack JS ── */}
<script is:inline>
(function() {
  // Substack email form
  var form = document.getElementById('substack-form');
  var emailInput = document.getElementById('substack-email');
  if (form && emailInput) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var email = emailInput.value.trim();
      if (email) {
        window.open('https://productimpactpod.substack.com/subscribe?email=' + encodeURIComponent(email), '_blank');
        emailInput.value = '';
      }
    });
  }

  // Substack editions are now fetched at build time — no client-side fetch needed

  var track = document.getElementById('hero-track');
  var dots = document.getElementById('hero-dots');
  var slides = document.querySelectorAll('.hero-slide');
  var prevBtn = document.getElementById('hero-prev');
  var nextBtn = document.getElementById('hero-next');
  if (!track || !dots || slides.length === 0) return;

  const dotBtns = dots.querySelectorAll('button');
  let current = 0;
  let autoTimer;

  function goTo(i) {
    current = ((i % slides.length) + slides.length) % slides.length;
    track.style.transform = 'translateX(-' + (current * 100) + '%)';
    dotBtns.forEach(function(d, j) {
      d.className = j === current
        ? 'h-2 rounded-full bg-white w-6 transition-all'
        : 'h-2 rounded-full bg-white/30 w-2 hover:bg-white/50 transition-all';
    });
  }

  function next() { goTo(current + 1); }
  function prev() { goTo(current - 1); }
  function startAuto() { stopAuto(); autoTimer = setInterval(next, 6000); }
  function stopAuto() { clearInterval(autoTimer); }

  dotBtns.forEach(function(btn, i) {
    btn.addEventListener('click', function() { goTo(i); startAuto(); });
  });
  if (prevBtn) prevBtn.addEventListener('click', function() { prev(); startAuto(); });
  if (nextBtn) nextBtn.addEventListener('click', function() { next(); startAuto(); });

  var touchStartX = 0;
  track.addEventListener('touchstart', function(e) { touchStartX = e.touches[0].clientX; stopAuto(); }, { passive: true });
  track.addEventListener('touchend', function(e) {
    var diff = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) { diff > 0 ? next() : prev(); }
    startAuto();
  }, { passive: true });

  startAuto();

  // Episode modal
  var modal = document.getElementById('ep-modal');
  var closeBtn = document.getElementById('ep-modal-close');
  if (modal && closeBtn) {
    document.querySelectorAll('.ep-modal-trigger').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var title = btn.getAttribute('data-title') || '';
        var desc = btn.getAttribute('data-desc') || '';
        var audio = btn.getAttribute('data-audio') || '';
        var image = btn.getAttribute('data-image') || '';
        var date = btn.getAttribute('data-date') || '';
        var ep = btn.getAttribute('data-ep') || '';
        var link = btn.getAttribute('data-link') || '';
        var dur = btn.getAttribute('data-duration') || '';

        document.getElementById('ep-modal-title').textContent = title;
        var descEl = document.getElementById('ep-modal-desc');
        descEl.innerHTML = desc;
        document.getElementById('ep-modal-num').textContent = ep;

        // Auto-detect themes from title+desc and render as clickable tags
        var themeMap = [
          { slug: 'ai-product-strategy', label: 'AI Product Strategy', color: '#ff6b4a', kw: ['product strategy','roadmap','product leader','strategic'] },
          { slug: 'adoption-organizational-change', label: 'Adoption & Org Change', color: '#f5a623', kw: ['adoption','organizational','transformation','enterprise','scaling'] },
          { slug: 'agents-agentic-systems', label: 'Agents & Agentic', color: '#9b7bff', kw: ['agent','agentic','autonomous','orchestrat','copilot'] },
          { slug: 'evaluation-benchmarking', label: 'Evaluation', color: '#6bbf71', kw: ['evaluat','benchmark','metric','measur','roi','kpi'] },
          { slug: 'governance-risk-trust', label: 'Governance & Trust', color: '#c96bff', kw: ['governance','risk','trust','safety','ethic','bias'] },
          { slug: 'ux-experience-design-for-ai', label: 'UX & Design', color: '#4ab8c9', kw: ['ux','user experience','design','interface','human-centered'] },
          { slug: 'data-semantics-knowledge-foundations', label: 'Data & Knowledge', color: '#5ba3cc', kw: ['data','knowledge','semantic','graph','rag','embedding'] },
          { slug: 'go-to-market-distribution', label: 'Go-to-Market', color: '#ff8566', kw: ['go-to-market','pricing','growth','distribution','launch'] },
        ];
        var text = (title + ' ' + desc).toLowerCase();
        var tagsHtml = '';
        themeMap.forEach(function(t) {
          if (t.kw.some(function(k) { return text.indexOf(k) !== -1; })) {
            tagsHtml += '<a href="/themes/' + t.slug + '/" class="px-2.5 py-1 rounded-full text-[11px] font-semibold" style="color:' + t.color + ';background:' + t.color + '12;border:1px solid ' + t.color + '25">' + t.label + '</a>';
          }
        });
        document.getElementById('ep-modal-tags').innerHTML = tagsHtml;
        document.getElementById('ep-modal-date').textContent = date;
        document.getElementById('ep-modal-dur').textContent = dur;
        document.getElementById('ep-modal-link').href = link || '#';

        var imgEl = document.getElementById('ep-modal-img');
        if (image) { imgEl.src = image; imgEl.style.display = ''; }
        else { imgEl.style.display = 'none'; }

        var audioWrap = document.getElementById('ep-modal-audio-wrap');
        if (audio) {
          audioWrap.innerHTML = '<audio controls preload="none" class="w-full rounded-lg" style="height:48px"><source src="' + audio + '" type="audio/mpeg" /></audio>';
        } else { audioWrap.innerHTML = ''; }

        var spotifyLink = document.getElementById('ep-modal-spotify');
        spotifyLink.href = 'https://open.spotify.com/show/3O11vQKPpKI5ZlJhdRGwnf';

        modal.classList.remove('hidden');
        modal.classList.add('flex');
      });
    });

    closeBtn.addEventListener('click', function() {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      var audioWrap = document.getElementById('ep-modal-audio-wrap');
      audioWrap.innerHTML = '';
    });

    modal.addEventListener('click', function(e) {
      if (e.target === modal) {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        var audioWrap = document.getElementById('ep-modal-audio-wrap');
        audioWrap.innerHTML = '';
      }
    });
  }
})();
</script>

