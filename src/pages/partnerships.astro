---
// /partnerships — sponsor portal.
// Audience profile, sponsorship formats, and contact flow.

import BaseLayout from "@layouts/BaseLayout.astro";
import Nav from "@components/Nav.astro";
import Footer from "@components/Footer.astro";

const siteUrl = "https://productimpactpod.com";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Partnerships | Product Impact",
  url: `${siteUrl}/partnerships`,
  isPartOf: { "@type": "WebSite", name: "Product Impact", url: siteUrl },
  description:
    "Sponsor Product Impact — podcast, newsletter, and editorial partnerships with an audience of AI product practitioners and leaders.",
};

const audienceStats = [
  { label: "Primary audience", value: "Product leaders" },
  { label: "Common roles", value: "VP Product, Head of AI, Principal PM, CTO, Founder" },
  { label: "Company stage", value: "Series A through enterprise" },
  { label: "Buying authority", value: "Decision-makers & influencers" },
];

const sponsorshipFormats = [
  {
    title: "Podcast pre-roll",
    description:
      "A 30-60 second host-read mention at the top of an episode. Heard by every listener, preserved in the episode archive.",
    positioning: "Brand awareness, product launches, category education.",
  },
  {
    title: "Podcast mid-roll",
    description:
      "A 60-90 second host-read integration in the middle of an episode. Higher attention, deeper message.",
    positioning: "Product-led stories, specific use cases, time-bound offers.",
  },
  {
    title: "Newsletter sponsorship",
    description:
      "A dedicated slot in our Substack newsletter, reaching subscribers directly in their inbox. Clearly labelled as sponsored.",
    positioning: "Direct response, webinar promotion, event invitations.",
  },
  {
    title: "Theme sponsor",
    description:
      "Named sponsor of one of our eight editorial themes for a quarter (e.g. \"Evaluation & Benchmarking, sponsored by ___\"). Placement on the theme hub page, newsletter section, and related episodes.",
    positioning:
      "Category leadership, platform launches, long-term brand association with a topic.",
  },
  {
    title: "Research partnership",
    description:
      "Co-produce a research report or case study series. You get the underlying research; we retain editorial independence over what's published.",
    positioning:
      "Thought leadership, lead generation via gated reports, industry benchmarks.",
  },
  {
    title: "Event & live partnership",
    description:
      "Collaboration on live recordings, workshops, or roundtables at your event or ours.",
    positioning:
      "Community-building, recruiting, direct customer conversations.",
  },
];

const editorialPrinciples = [
  {
    principle: "Editorial independence",
    description:
      "Sponsorships never influence editorial coverage. Sponsors do not review editorial articles before publication. We may cover a sponsor's product critically if the story warrants it.",
  },
  {
    principle: "Clear labelling",
    description:
      "Every sponsored segment is clearly labelled — in podcast audio, in newsletter placements, and on any sponsored page. Readers and listeners always know what's editorial and what's paid.",
  },
  {
    principle: "No pay-for-play coverage",
    description:
      "We don't sell editorial articles, guest appearances, or favourable coverage. If a sponsor wants earned coverage, they need to pitch a story our editors find interesting — on the same terms as anyone else.",
  },
  {
    principle: "Category fit",
    description:
      "We partner with companies whose products and services are genuinely relevant to our practitioner audience. We turn down sponsorships that don't fit — including in categories we think are misleading or harmful.",
  },
  {
    principle: "Disclosure of relationships",
    description:
      "When editorial coverage touches a current or recent sponsor, we disclose the relationship in the article. This is a feature, not a bug — our audience expects it.",
  },
];
---

<BaseLayout
  title="Partnerships | Product Impact"
  description="Sponsor Product Impact — podcast, newsletter, and editorial partnerships reaching AI product practitioners and leaders."
  canonicalUrl={`${siteUrl}/partnerships`}
  jsonLd={jsonLd}
>
  <Nav />

  <main>
    {/* Hero */}
    <section class="bg-background-elevated border-b border-[#2a2a2a]">
      <div class="container-wide py-20 md:py-24 max-w-4xl mx-auto">
        <div class="inline-flex items-center px-3 py-1 rounded-full bg-accent/10 border border-accent/30 text-accent text-xs font-bold uppercase tracking-wider mb-6">
          Partnerships
        </div>
        <h1 class="text-5xl md:text-6xl font-extrabold tracking-tight text-white leading-[1.05] mb-6">
          Reach the people<br />building AI products.
        </h1>
        <p class="text-xl text-[#d4d4d4] leading-relaxed max-w-3xl">
          Product Impact is read and listened to by product leaders,
          researchers, and practitioners making decisions about AI products
          today. If that's who you want to reach, let's talk.
        </p>
        <div class="mt-8">
          <a
            href="mailto:partner@productimpactpod.com?subject=Partnership inquiry"
            class="inline-flex items-center px-6 py-3 rounded-full bg-accent text-black font-bold text-sm hover:bg-accent-hover transition-colors"
          >
            Get in touch →
          </a>
        </div>
      </div>
    </section>

    {/* Audience */}
    <section class="container-wide py-16 max-w-4xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-extrabold uppercase tracking-tight text-white mb-8">
        Audience
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-10">
        {audienceStats.map((stat) => (
          <div class="bg-background-card rounded-xl p-6">
            <div class="text-xs uppercase tracking-wider text-[#707070] mb-1">
              {stat.label}
            </div>
            <div class="text-lg font-semibold text-white">{stat.value}</div>
          </div>
        ))}
      </div>
      <p class="text-[#d4d4d4] leading-relaxed">
        Our audience skews senior and technical. They're the people weighing
        build-versus-buy decisions for AI products, picking platforms and
        tools, setting product strategy, and owning the outcomes of AI
        deployments. They're not looking for hype — they're looking for the
        practitioners' view of what's actually working.
      </p>
      <p class="text-[#d4d4d4] leading-relaxed mt-4">
        Industries most represented: B2B software, fintech, healthtech, retail
        &amp; commerce, professional services, and large enterprise IT. The
        audience is global, with concentration in North America and Western
        Europe.
      </p>
      <p class="text-sm text-[#707070] italic mt-4">
        Detailed audience numbers (listener counts, subscriber counts,
        demographics, engagement rates) are shared in our media kit — email{" "}
        <a href="mailto:partner@productimpactpod.com" class="text-accent hover:text-accent-hover">
          partner@productimpactpod.com
        </a>{" "}
        to request it.
      </p>
    </section>

    {/* Sponsorship formats */}
    <section class="bg-background-elevated border-y border-[#2a2a2a] py-16">
      <div class="container-wide max-w-4xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-extrabold uppercase tracking-tight text-white mb-8">
          Sponsorship formats
        </h2>
        <div class="space-y-4">
          {sponsorshipFormats.map((format) => (
            <div class="bg-background-card rounded-xl p-6">
              <h3 class="text-xl font-bold text-white mb-2">{format.title}</h3>
              <p class="text-[#d4d4d4] leading-relaxed mb-3">
                {format.description}
              </p>
              <div class="text-sm">
                <span class="text-[#707070] uppercase tracking-wider text-xs">Best for:</span>
                <span class="text-[#a0a0a0] ml-2">{format.positioning}</span>
              </div>
            </div>
          ))}
        </div>
        <p class="text-sm text-[#a0a0a0] mt-6">
          Custom formats and bundled packages available. Most partnerships
          combine two or more of the above.
        </p>
      </div>
    </section>

    {/* Editorial independence */}
    <section class="container-wide py-16 max-w-4xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-extrabold uppercase tracking-tight text-white mb-8">
        How we work with sponsors
      </h2>
      <div class="space-y-4">
        {editorialPrinciples.map((p) => (
          <div class="bg-background-card rounded-xl p-6 border-l-4 border-accent">
            <h3 class="font-bold text-white mb-2">{p.principle}</h3>
            <p class="text-[#d4d4d4] leading-relaxed">{p.description}</p>
          </div>
        ))}
      </div>
      <p class="text-sm text-[#707070] italic mt-6">
        For the full picture of our editorial standards, see{" "}
        <a href="/about#editorial-standards" class="text-accent hover:text-accent-hover">
          About &amp; Editorial Standards
        </a>
        .
      </p>
    </section>

    {/* Process */}
    <section class="bg-background-elevated border-y border-[#2a2a2a] py-16">
      <div class="container-wide max-w-4xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-extrabold uppercase tracking-tight text-white mb-8">
          Getting started
        </h2>
        <ol class="space-y-5">
          <li class="flex gap-5">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-accent text-black font-bold flex items-center justify-center">1</div>
            <div>
              <h3 class="font-bold text-white mb-1">Intro email</h3>
              <p class="text-[#d4d4d4] leading-relaxed">
                Email{" "}
                <a href="mailto:partner@productimpactpod.com" class="text-accent hover:text-accent-hover">
                  partner@productimpactpod.com
                </a>{" "}
                with a sentence or two on your company, your audience, and what
                you're hoping to accomplish. We'll reply within three business
                days.
              </p>
            </div>
          </li>
          <li class="flex gap-5">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-accent text-black font-bold flex items-center justify-center">2</div>
            <div>
              <h3 class="font-bold text-white mb-1">Media kit &amp; fit check</h3>
              <p class="text-[#d4d4d4] leading-relaxed">
                We send our current media kit with audience numbers, formats,
                rates, and upcoming editorial calendar. If there's a clear
                fit, we schedule a 30-minute call.
              </p>
            </div>
          </li>
          <li class="flex gap-5">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-accent text-black font-bold flex items-center justify-center">3</div>
            <div>
              <h3 class="font-bold text-white mb-1">Scope &amp; agreement</h3>
              <p class="text-[#d4d4d4] leading-relaxed">
                We agree on formats, timing, messaging, and deliverables in
                writing. Short insertion orders for single-placement
                sponsorships; longer-form agreements for theme sponsorships or
                research partnerships.
              </p>
            </div>
          </li>
          <li class="flex gap-5">
            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-accent text-black font-bold flex items-center justify-center">4</div>
            <div>
              <h3 class="font-bold text-white mb-1">Launch &amp; report</h3>
              <p class="text-[#d4d4d4] leading-relaxed">
                We produce and publish. After the campaign, we share
                performance reporting — download numbers, newsletter engagement,
                website referrals where applicable.
              </p>
            </div>
          </li>
        </ol>
      </div>
    </section>

    {/* Final CTA */}
    <section class="container-wide py-16 max-w-3xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-4 tracking-tight">
        Ready to talk?
      </h2>
      <p class="text-[#d4d4d4] mb-8 leading-relaxed">
        Most partnerships start with a short email. Tell us what you're trying
        to accomplish and we'll tell you whether we can help.
      </p>
      <a
        href="mailto:partner@productimpactpod.com?subject=Partnership inquiry"
        class="inline-flex items-center px-6 py-3 rounded-full bg-accent text-black font-bold text-sm hover:bg-accent-hover transition-colors"
      >
        partner@productimpactpod.com →
      </a>
    </section>
  </main>

  <Footer />
</BaseLayout>
