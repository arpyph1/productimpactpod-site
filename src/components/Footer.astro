---
// Footer — compact, professional, reads social links from CMS.
import { getSiteSetting } from "@lib/supabase";

const social = (await getSiteSetting("social_links")) ?? {};
const spotifyUrl = social.spotify ?? "https://open.spotify.com/show/3O11vQKPpKI5ZlJhdRGwnf";
const appleUrl = social.apple ?? "https://podcasts.apple.com/us/podcast/product-impact-podcast-formerly-design-of-ai/id1734499859";
const youtubeUrl = social.youtube ?? "https://www.youtube.com/channel/UCb1nY02YcJYZZ_XtvcIBcrw";
const substackUrl = social.substack ?? "https://productimpactpod.substack.com";
const linkedinUrl = social.linkedin ?? "https://www.linkedin.com/company/product-impact-podcast";
---

<footer class="border-t border-[#141414] mt-16">
  <div class="container-wide py-10">

    {/* Top row: platform logos */}
    <div class="flex flex-wrap items-center justify-center gap-8 mb-16 pt-4">
      <a href={spotifyUrl} target="_blank" rel="noopener" class="opacity-50 hover:opacity-100 transition-opacity" title="Spotify">
        <svg viewBox="0 0 168 168" class="w-8 h-8"><path fill="#1DB954" d="M83.996.277C37.747.277.253 37.77.253 84.019c0 46.251 37.494 83.741 83.743 83.741 46.254 0 83.744-37.49 83.744-83.741 0-46.246-37.49-83.738-83.745-83.738l.001-.004zm38.404 120.78a5.217 5.217 0 01-7.18 1.73c-19.662-12.01-44.414-14.73-73.564-8.07a5.222 5.222 0 01-6.249-3.93 5.213 5.213 0 013.926-6.25c31.9-7.291 59.263-4.15 81.337 9.34 2.46 1.51 3.24 4.72 1.73 7.18zm10.25-22.805c-1.89 3.075-5.91 4.045-8.98 2.155-22.51-13.839-56.823-17.846-83.448-9.764-3.453 1.043-7.1-.903-8.148-4.35a6.538 6.538 0 014.354-8.143c30.413-9.228 68.222-4.758 94.072 11.127 3.07 1.89 4.04 5.91 2.15 8.976zm.88-23.744c-26.99-16.031-71.52-17.505-97.289-9.684-4.138 1.255-8.514-1.081-9.768-5.219a7.835 7.835 0 015.221-9.771c29.581-8.98 78.756-7.245 109.83 11.202a7.823 7.823 0 012.74 10.733c-2.2 3.722-7.02 4.949-10.73 2.739z"/></svg>
      </a>
      <a href={appleUrl} target="_blank" rel="noopener" class="opacity-50 hover:opacity-100 transition-opacity" title="Apple Podcasts">
        <svg viewBox="0 0 32 32" class="w-8 h-8"><path fill="#BC5FE8" d="M16 0C7.163 0 0 7.163 0 16s7.163 16 16 16 16-7.163 16-16S24.837 0 16 0zm0 4.8a11.2 11.2 0 110 22.4 11.2 11.2 0 010-22.4zm0 3.2a8 8 0 100 16 8 8 0 000-16zm0 2.4a2.8 2.8 0 110 5.6 2.8 2.8 0 010-5.6zm-1.6 7.2h3.2l.8 7.6h-4.8l.8-7.6z"/></svg>
      </a>
      <a href={youtubeUrl} target="_blank" rel="noopener" class="opacity-50 hover:opacity-100 transition-opacity" title="YouTube">
        <svg viewBox="0 0 24 24" class="w-8 h-8"><path fill="#FF0000" d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
      </a>
      <a href={substackUrl} target="_blank" rel="noopener" class="opacity-50 hover:opacity-100 transition-opacity" title="Substack">
        <svg viewBox="0 0 24 24" class="w-8 h-8"><path fill="#FF6719" d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24l9.54-5.584L20.539 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z"/></svg>
      </a>
      <a href={linkedinUrl} target="_blank" rel="noopener" class="opacity-50 hover:opacity-100 transition-opacity" title="LinkedIn">
        <svg viewBox="0 0 24 24" class="w-8 h-8"><path fill="#0077B5" d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </a>
    </div>

    {/* Grid */}
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-10">

      {/* Brand */}
      <div class="col-span-2 md:col-span-1">
        <div class="flex items-center gap-2 mb-2">
          <div class="w-6 h-6 rounded bg-[#ff6b4a] flex items-center justify-center flex-shrink-0">
            <span class="text-white font-black text-[8px]">PI</span>
          </div>
          <span class="text-[13px] font-bold text-white">Product Impact</span>
        </div>
        <p class="text-[12px] text-[#666] leading-relaxed max-w-[220px]">
          AI product impact — news, releases, and case studies.
        </p>
      </div>

      {/* Navigate */}
      <div>
        <h3 class="text-[10px] font-bold uppercase tracking-wider text-[#555] mb-3">Navigate</h3>
        <ul class="space-y-1.5">
          {["Home:/", "News:/news/", "Themes:/themes/", "Companies:/companies/", "Podcast:/podcast/", "Episodes:/episodes/", "Partner:/partnerships/"].map((item) => {
            const [label, href] = item.split(":");
            return <li><a href={href} class="text-[12px] text-[#888] hover:text-white transition-colors">{label}</a></li>;
          })}
        </ul>
      </div>

      {/* Feeds */}
      <div>
        <h3 class="text-[10px] font-bold uppercase tracking-wider text-[#555] mb-3">Feeds</h3>
        <ul class="space-y-1.5">
          <li><a href="/rss.xml" class="text-[12px] text-[#888] hover:text-white">Main RSS</a></li>
          <li><a href="/news/rss.xml" class="text-[12px] text-[#888] hover:text-white">News RSS</a></li>
          <li><a href="/podcast/rss.xml" class="text-[12px] text-[#888] hover:text-white">Podcast RSS</a></li>
          <li><a href="/sitemap.xml" class="text-[12px] text-[#888] hover:text-white">Sitemap</a></li>
        </ul>
      </div>

      {/* Contact */}
      <div>
        <h3 class="text-[10px] font-bold uppercase tracking-wider text-[#555] mb-3">Contact</h3>
        <ul class="space-y-1.5">
          <li><a href="mailto:info@productimpactpod.com" class="text-[12px] text-[#888] hover:text-white">info@productimpactpod.com</a></li>
          <li><a href="/partnerships/" class="text-[12px] text-[#ff6b4a] hover:text-[#ff8566]">Partner with us →</a></li>
          <li><a href="/admin/" class="text-[12px] text-[#444] hover:text-[#888] transition-colors">CMS</a></li>
        </ul>
      </div>
    </div>

    {/* Bottom */}
    <div class="pt-6 border-t border-[#141414] flex flex-col sm:flex-row items-start sm:items-center justify-between gap-2">
      <p class="text-[11px] text-[#444]">© 2026 Product Impact. All rights reserved.</p>
      <div class="flex gap-4 text-[11px] text-[#444]">
        <a href="/privacy/" class="hover:text-white">Privacy</a>
        <a href="/terms/" class="hover:text-white">Terms</a>
      </div>
    </div>
  </div>
</footer>
