---
// Footer — listen links, nav, legal, RSS discovery.
---

<footer class="bg-background-elevated border-t border-[#2a2a2a] mt-24">
  <div class="container-wide py-12">
    <!-- Listen links row -->
    <div class="flex flex-wrap items-center justify-center gap-6 mb-12">
      <a
        href="https://open.spotify.com/show/productimpactpod"
        target="_blank"
        rel="noopener"
        class="flex items-center gap-2 bg-background-card px-4 py-2 rounded-full text-sm font-semibold text-white hover:bg-background-hover transition-colors"
      >
        <span class="w-5 h-5 rounded-full bg-[#1DB954]"></span>
        Spotify
      </a>
      <a
        href="https://podcasts.apple.com/productimpactpod"
        target="_blank"
        rel="noopener"
        class="flex items-center gap-2 bg-background-card px-4 py-2 rounded-full text-sm font-semibold text-white hover:bg-background-hover transition-colors"
      >
        <span class="w-5 h-5 rounded-full bg-[#BC5FE8]"></span>
        Apple Podcasts
      </a>
      <a
        href="https://youtube.com/@productimpactpod"
        target="_blank"
        rel="noopener"
        class="flex items-center gap-2 bg-background-card px-4 py-2 rounded-full text-sm font-semibold text-white hover:bg-background-hover transition-colors"
      >
        <span class="w-5 h-5 rounded-full bg-[#FF0000]"></span>
        YouTube
      </a>
      <a
        href="https://productimpactpod.substack.com"
        target="_blank"
        rel="noopener"
        class="flex items-center gap-2 bg-background-card px-4 py-2 rounded-full text-sm font-semibold text-white hover:bg-background-hover transition-colors"
      >
        <span class="w-5 h-5 rounded-full bg-[#FF6719]"></span>
        Substack
      </a>
      <a
        href="https://linkedin.com/company/product-impact-podcast"
        target="_blank"
        rel="noopener"
        class="flex items-center gap-2 bg-background-card px-4 py-2 rounded-full text-sm font-semibold text-white hover:bg-background-hover transition-colors"
      >
        <span class="w-5 h-5 rounded-full bg-[#0077B5]"></span>
        LinkedIn
      </a>
    </div>

    <!-- Footer nav grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
      <!-- Brand column -->
      <div>
        <div class="flex items-center gap-3 mb-3">
          <img
            src="/logo.png"
            alt="Product Impact Podcast"
            width="56"
            height="56"
            class="h-14 w-14 rounded-full"
          />
          <div>
            <div class="font-bold text-xl text-white">Product Impact Podcast</div>
            <div class="text-sm text-[#a0a0a0]">Formerly Design of AI Podcast</div>
          </div>
        </div>
        <p class="text-sm text-[#a0a0a0] max-w-md leading-relaxed">
          AI product impact — news, releases, and case studies about the products transforming how we work and industries.
        </p>
      </div>

      <!-- Navigate column -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-wider text-[#707070] mb-4">Navigate</h3>
        <ul class="space-y-2 text-sm text-[#d4d4d4]">
          <li><a href="/" class="hover:text-white">Home</a></li>
          <li><a href="/news" class="hover:text-white">News</a></li>
          <li><a href="/themes" class="hover:text-white">Themes</a></li>
          <li><a href="/podcast" class="hover:text-white">Podcast</a></li>
          <li><a href="/episodes" class="hover:text-white">Episodes</a></li>
          <li><a href="/partnerships" class="hover:text-white">Partnerships</a></li>
          <li><a href="/about" class="hover:text-white">About</a></li>
        </ul>
      </div>

      <!-- Feeds + contact column -->
      <div>
        <h3 class="text-xs font-bold uppercase tracking-wider text-[#707070] mb-4">Feeds & Contact</h3>
        <ul class="space-y-2 text-sm text-[#d4d4d4]">
          <li><a href="/rss.xml" class="hover:text-white">Main RSS feed</a></li>
          <li><a href="/news/rss.xml" class="hover:text-white">News RSS feed</a></li>
          <li><a href="/podcast/rss.xml" class="hover:text-white">Podcast RSS feed</a></li>
          <li><a href="/sitemap.xml" class="hover:text-white">Sitemap</a></li>
          <li>
            <a href="mailto:info@productimpactpod.com" class="hover:text-white">
              info@productimpactpod.com
            </a>
          </li>
          <li>
            <a href="/contact" class="text-accent hover:text-accent-hover">
              Get in Touch →
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Copyright -->
    <div class="pt-8 border-t border-[#2a2a2a] flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
      <p class="text-xs text-[#707070]">
        © 2026 Product Impact Podcast. All rights reserved.
      </p>
      <div class="flex items-center gap-4 text-xs text-[#707070]">
        <a href="/privacy" class="hover:text-white">Privacy</a>
        <a href="/terms" class="hover:text-white">Terms</a>
      </div>
    </div>
  </div>
</footer>
