---
// Hosts — large vertical 9:16 portraits matching Lovable's Hosts.tsx.
// Each host: tall photo, name + role below, bio paragraph, LinkedIn link.
//
// Host photo URLs come from the entities table (external_links or metadata)
// or a direct prop. Falls back to a branded placeholder if no image set.

import { getEntityBySlug } from "@lib/supabase";

interface HostConfig {
  slug: string;
  nameFallback: string;
  roleFallback: string;
  bioFallback: string;
  linkedinFallback: string;
}

const HOSTS: HostConfig[] = [
  {
    slug: "arpy-dragffy",
    nameFallback: "Arpy Dragffy",
    roleFallback: "Founder & Co-host",
    bioFallback:
      "Founder of PH1 Research and AI Value Acceleration. Focused on enterprise AI adoption and product-impact research. Co-host and producer of Product Impact Podcast.",
    linkedinFallback: "https://linkedin.com/in/arpydragffy",
  },
  {
    slug: "brittany-hobbs",
    nameFallback: "Brittany Hobbs",
    roleFallback: "Co-host",
    bioFallback:
      "Product leader at the intersection of AI capabilities, product strategy, and go-to-market. Explores what it takes to ship AI products that people actually use.",
    linkedinFallback: "https://linkedin.com/in/brittanyhobbs",
  },
];

const hosts = await Promise.all(
  HOSTS.map(async (h) => {
    const entity = await getEntityBySlug("person", h.slug);
    const linkedin =
      entity?.external_links?.find((l) => l.label?.toLowerCase() === "linkedin")?.url ??
      h.linkedinFallback;
    // Host photo: prefer metadata.photo_url, then schema_jsonld.image, else null
    const metadata = (entity?.metadata ?? {}) as Record<string, unknown>;
    const photoUrl =
      (typeof metadata.photo_url === "string" && metadata.photo_url) ||
      (typeof metadata.image_url === "string" && metadata.image_url) ||
      null;

    return {
      slug: h.slug,
      name: entity?.name ?? h.nameFallback,
      role: h.roleFallback,
      bio: entity?.description ?? h.bioFallback,
      photoUrl,
      linkedin,
    };
  }),
);
---

<section id="hosts" class="bg-background" aria-label="Podcast hosts">
  <div class="container-wide py-16">
    {/* Section header */}
    <div class="flex items-end justify-between pb-10 border-b border-border gap-4 flex-wrap">
      <h3
        class="font-display font-extrabold uppercase leading-none tracking-tight text-foreground"
        style="font-size: clamp(1.5rem, 3.5vw, 2.8rem); letter-spacing: -0.02em;"
      >
        Hosts
      </h3>
      <span class="text-xs text-muted-foreground">Meet the team</span>
    </div>

    {/* 2-column grid on desktop, single column on mobile */}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 pt-12">
      {hosts.map((host) => (
        <div class="flex flex-col gap-5">
          {/* Vertical 9:16 photo */}
          <div
            class="relative w-full rounded-xl overflow-hidden bg-card border border-border group shadow-xl"
            style="aspect-ratio: 9 / 16;"
          >
            {host.photoUrl ? (
              <>
                <img
                  src={host.photoUrl}
                  alt={`${host.name} — ${host.role}`}
                  loading="lazy"
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.04]"
                />
                <div class="absolute inset-0 bg-black/30 group-hover:bg-black/10 transition-all duration-500"></div>
              </>
            ) : (
              /* Placeholder: gradient + initial */
              <div class="w-full h-full bg-gradient-to-br from-primary/20 via-card to-card flex items-center justify-center">
                <span class="font-display font-extrabold text-foreground/20" style="font-size: 8rem;">
                  {host.name.charAt(0)}
                </span>
              </div>
            )}
          </div>

          {/* Text below photo */}
          <div>
            <div class="flex items-baseline gap-3 mb-2 flex-wrap">
              <h3
                class="font-display font-extrabold leading-none tracking-tight text-foreground"
                style="font-size: clamp(1.3rem, 2.5vw, 1.8rem);"
              >
                {host.name}
              </h3>
              <span class="text-xs font-semibold uppercase tracking-widest text-primary">
                {host.role}
              </span>
            </div>

            <p class="text-base text-muted-foreground leading-relaxed mb-4">{host.bio}</p>

            <div class="flex items-center gap-4">
              <a
                href={`/people/${host.slug}`}
                class="text-sm text-primary hover:underline font-medium inline-flex items-center gap-1"
              >
                View profile
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <line x1="7" y1="17" x2="17" y2="7" /><polyline points="7 7 17 7 17 17" />
                </svg>
              </a>
              {host.linkedin && (
                <a
                  href={host.linkedin}
                  target="_blank"
                  rel="noopener"
                  class="text-sm text-muted-foreground hover:text-foreground transition-colors inline-flex items-center gap-1"
                  aria-label={`${host.name} on LinkedIn`}
                >
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.063 2.063 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                  </svg>
                  LinkedIn
                </a>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
  <div class="section-divider"></div>
</section>
