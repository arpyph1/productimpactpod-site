---
// EntityHeadline — renders a headline with entity names highlighted in coral.
// Uses a built-in keyword dictionary of known entities (companies, people, products).
// Any matching name in the headline gets wrapped in a coral <span>.
//
// This approach doesn't depend on per-article entity metadata — it matches
// against a global dictionary, similar to how Particle.news highlights
// "OpenAI", "ChatGPT", "Palantir" etc in every headline.

export interface Props {
  title: string;
  entities?: string[]; // Optional additional slugs to highlight
  class?: string;
  tag?: "h1" | "h2" | "h3" | "span";
}

const {
  title,
  entities = [],
  class: className = "",
  tag = "h2",
} = Astro.props;

