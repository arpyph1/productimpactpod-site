// Convert slugs to display names and add to the list
function slugToName(slug: string): string {
  return slug.replace(/-/g, " ").replace(/\b\w/g, (c) => c.toUpperCase());
}

const allEntities = [
  ...KNOWN_ENTITIES,
  ...entities.map(slugToName),
];

// Deduplicate and sort by length (longest first so "Claude Managed Agents" matches before "Claude")
const uniqueNames = [...new Set(allEntities)].sort((a, b) => b.length - a.length);

function escapeHtml(str: string): string {
  return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
}

function escapeRegex(str: string): string {
  return str.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
}

// Build highlighted HTML
function highlightEntities(text: string, names: string[]): string {
  if (!names.length) return escapeHtml(text);

  let result = text;
  const replacements: Array<{ placeholder: string; html: string }> = [];

  names.forEach((name, i) => {
    const regex = new RegExp(`\\b${escapeRegex(name)}\\b`, "gi");
    if (!regex.test(result)) return; // skip if not in title
    regex.lastIndex = 0;
    const placeholder = `\x00ENT${i}\x00`;
    result = result.replace(regex, placeholder);
    replacements.push({
      placeholder,
      html: `<span style="color:#ff6b4a">${escapeHtml(name)}</span>`,
    });
  });

  let escaped = escapeHtml(result);
  replacements.forEach(({ placeholder, html }) => {
    escaped = escaped.replaceAll(escapeHtml(placeholder), html);
  });

  return escaped;
}

const html = highlightEntities(title, uniqueNames);
const Tag = tag;
---

<Tag class={className} set:html={html} />
