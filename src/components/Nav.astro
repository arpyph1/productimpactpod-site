---
// Nav — centered logo, mega menu dropdowns for News/Themes, scroll-aware.
---

<header>
  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-transparent transition-all duration-300" id="main-nav">
    <div class="container-wide flex items-center justify-between transition-all duration-300" style="height: 96px;" id="nav-inner">

      {/* Left nav items — with mega menu dropdowns */}
      <div class="hidden md:flex items-center gap-6 flex-1">
        {/* News dropdown */}
        <div class="relative" id="news-dropdown-wrap">
          <button class="text-[13px] font-medium text-white/60 hover:text-white transition-colors flex items-center gap-1" id="news-trigger">
            News
            <svg class="w-3 h-3 opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="absolute top-full left-0 mt-3 w-[520px] rounded-xl shadow-2xl p-6 z-50 hidden border border-[#2a2a2a]" id="news-dropdown" style="background: linear-gradient(165deg, #1a1a1a 0%, #111 100%);">
            <div class="flex items-center justify-between mb-4">
              <span class="text-[11px] font-semibold text-[#777] uppercase tracking-wider">Browse by format</span>
              <a href="/news/" class="text-[12px] text-[#ff6b4a] hover:text-[#ff8566] font-semibold">View all →</a>
            </div>
            <div class="grid grid-cols-2 gap-1">
              {[
                { label: "All News", href: "/news/", desc: "Everything published" },
                { label: "Features", href: "/news/format/feature/", desc: "In-depth reporting" },
                { label: "News Analysis", href: "/news/format/news-analysis/", desc: "What it means" },
                { label: "Case Studies", href: "/news/format/case-study/", desc: "Real-world impact" },
                { label: "Releases", href: "/news/format/release-note/", desc: "Product launches" },
                { label: "Interviews", href: "/news/format/interview/", desc: "Conversations with leaders" },
              ].map((item) => (
                <a href={item.href} class="flex flex-col px-4 py-3 rounded-lg hover:bg-white/[0.06] transition-colors">
                  <span class="text-[15px] font-semibold text-[#e0e0e0] hover:text-white">{item.label}</span>
                  <span class="text-[12px] text-[#666] mt-0.5">{item.desc}</span>
                </a>
              ))}
            </div>
          </div>
        </div>

        {/* Themes dropdown */}
        <div class="relative" id="themes-dropdown-wrap">
          <button class="text-[13px] font-medium text-white/60 hover:text-white transition-colors flex items-center gap-1" id="themes-trigger">
            Themes
            <svg class="w-3 h-3 opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="absolute top-full left-0 mt-3 w-[560px] rounded-xl shadow-2xl p-6 z-50 hidden border border-[#2a2a2a]" id="themes-dropdown" style="background: linear-gradient(165deg, #1a1a1a 0%, #111 100%);">
            <div class="flex items-center justify-between mb-4">
              <span class="text-[11px] font-semibold text-[#777] uppercase tracking-wider">Explore themes</span>
              <a href="/themes/" class="text-[12px] text-[#ff6b4a] hover:text-[#ff8566] font-semibold">View all →</a>
            </div>
            <div class="grid grid-cols-2 gap-1">
              {[
                { label: "AI Product Strategy", slug: "ai-product-strategy", color: "#ff6b4a" },
                { label: "Agents & Agentic Systems", slug: "agents-agentic-systems", color: "#9b7bff" },
                { label: "UX & Design for AI", slug: "ux-experience-design-for-ai", color: "#4ab8c9" },
                { label: "Adoption & Org Change", slug: "adoption-organizational-change", color: "#f5a623" },
                { label: "Evaluation & Benchmarking", slug: "evaluation-benchmarking", color: "#6bbf71" },
                { label: "Go-to-Market", slug: "go-to-market-distribution", color: "#ff8566" },
                { label: "Data & Knowledge", slug: "data-semantics-knowledge-foundations", color: "#5ba3cc" },
                { label: "Governance & Trust", slug: "governance-risk-trust", color: "#c96bff" },
              ].map((t) => (
                <a href={`/themes/${t.slug}/`} class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/[0.06] transition-colors">
                  <div class="w-2.5 h-2.5 rounded-full flex-shrink-0" style={`background: ${t.color}; box-shadow: 0 0 8px ${t.color}40`}></div>
                  <span class="text-[15px] font-semibold text-[#e0e0e0] hover:text-white">{t.label}</span>
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>

      {/* Center logo */}
      <a href="/" class="flex items-center justify-center flex-shrink-0">
        <img src="/logo.png" alt="Product Impact Podcast" class="object-contain transition-all duration-300" style="width: 90px; height: 90px;" id="nav-logo" />
      </a>

      {/* Right nav items */}
      <div class="hidden md:flex items-center justify-end gap-6 flex-1">
        <a href="/podcast/" class="text-[13px] font-medium text-white/60 hover:text-white transition-colors">Podcast</a>
        <a href="/episodes/" class="text-[13px] font-medium text-white/60 hover:text-white transition-colors">Episodes</a>
        <a href="/partnerships/" class="text-[13px] font-medium text-white/60 hover:text-white transition-colors">Partner</a>
      </div>

      {/* Mobile hamburger */}
      <button type="button" aria-label="Menu" class="md:hidden p-1.5 text-white/60 hover:text-white" id="nav-toggle">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="4" y1="6" x2="20" y2="6"></line>
          <line x1="4" y1="12" x2="20" y2="12"></line>
          <line x1="4" y1="18" x2="20" y2="18"></line>
        </svg>
      </button>
    </div>

    {/* Mobile menu */}
    <div id="nav-menu" class="md:hidden hidden border-t border-white/5 bg-[#0a0a0a]/95 backdrop-blur-md">
      <div class="py-3 px-6">
        <a href="/news/" class="block py-2.5 text-[14px] font-medium text-white/70 hover:text-white">News</a>
        <a href="/themes/" class="block py-2.5 text-[14px] font-medium text-white/70 hover:text-white">Themes</a>
        <a href="/podcast/" class="block py-2.5 text-[14px] font-medium text-white/70 hover:text-white">Podcast</a>
        <a href="/episodes/" class="block py-2.5 text-[14px] font-medium text-white/70 hover:text-white">Episodes</a>
        <a href="/partnerships/" class="block py-2.5 text-[14px] font-medium text-white/70 hover:text-white">Partner</a>
      </div>
    </div>
  </nav>
  {/* Spacer */}
  <div style="height: 96px;"></div>
</header>

<script is:inline>
(function() {
  var nav = document.getElementById('main-nav');
  var inner = document.getElementById('nav-inner');
  var logo = document.getElementById('nav-logo');
  var toggle = document.getElementById('nav-toggle');
  var menu = document.getElementById('nav-menu');

  // Scroll: compact nav
  var scrolled = false;
  window.addEventListener('scroll', function() {
    var now = window.scrollY > 40;
    if (now !== scrolled) {
      scrolled = now;
      if (scrolled) {
        nav.style.background = 'rgba(8,8,8,0.95)';
        nav.style.backdropFilter = 'blur(12px)';
        nav.style.borderColor = 'rgba(255,255,255,0.06)';
        inner.style.height = '64px';
        logo.style.width = '67px';
        logo.style.height = '67px';
      } else {
        nav.style.background = 'rgba(8,8,8,0.6)';
        nav.style.backdropFilter = 'blur(8px)';
        nav.style.borderColor = 'transparent';
        inner.style.height = '96px';
        logo.style.width = '90px';
        logo.style.height = '90px';
      }
    }
  }, { passive: true });

  // Mobile toggle
  if (toggle && menu) {
    toggle.addEventListener('click', function() {
      menu.classList.toggle('hidden');
    });
  }

  // Mega menu dropdowns
  function setupDropdown(triggerId, dropdownId, wrapId) {
    var trigger = document.getElementById(triggerId);
    var dropdown = document.getElementById(dropdownId);
    var wrap = document.getElementById(wrapId);
    if (!trigger || !dropdown || !wrap) return;
    var timeout;

    function show() { clearTimeout(timeout); dropdown.classList.remove('hidden'); }
    function hide() { timeout = setTimeout(function() { dropdown.classList.add('hidden'); }, 150); }

    wrap.addEventListener('mouseenter', show);
    wrap.addEventListener('mouseleave', hide);
    trigger.addEventListener('click', function(e) {
      e.preventDefault();
      dropdown.classList.toggle('hidden');
    });
    // Close on click outside
    document.addEventListener('click', function(e) {
      if (!wrap.contains(e.target)) dropdown.classList.add('hidden');
    });
  }

  setupDropdown('news-trigger', 'news-dropdown', 'news-dropdown-wrap');
  setupDropdown('themes-trigger', 'themes-dropdown', 'themes-dropdown-wrap');
})();
</script>
