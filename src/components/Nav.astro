---
// Nav — centered logo, mega menu dropdowns for News/Themes, scroll-aware.
// Mobile: 64px tall with a compact 48px logo. Desktop: 120px expanded /
// 80px scrolled with a large logo. Spacer auto-tracks the desktop expanded
// height so initial layout doesn't sit under the nav.
---

<header>
  <nav
    class="fixed top-0 left-0 right-0 z-50 border-b border-transparent transition-all duration-300"
    id="main-nav"
  >
    <div
      class="container-wide flex items-center justify-between transition-all duration-300 h-[64px] md:h-[120px]"
      id="nav-inner"
    >

      {/* Left nav items — with mega menu dropdowns */}
      <div class="hidden md:flex items-center gap-6 flex-1">
        {/* News dropdown */}
        <div class="relative" id="news-dropdown-wrap">
          <button class="text-[13px] font-medium text-white/60 hover:text-white transition-colors flex items-center gap-1" id="news-trigger">
            News
            <svg class="w-3 h-3 opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="absolute top-full left-0 mt-3 w-[520px] rounded-xl shadow-2xl p-6 z-50 hidden border border-[#2a2a2a]" id="news-dropdown" style="background: linear-gradient(165deg, #1a1a1a 0%, #111 100%);">
            <div class="flex items-center justify-between mb-4">
              <span class="text-[11px] font-semibold text-[#777] uppercase tracking-wider">Browse by format</span>
              <a href="/news/" class="text-[12px] text-[#ff6b4a] hover:text-[#ff8566] font-semibold">View all →</a>
            </div>
            <div class="grid grid-cols-2 gap-1">
              {[
                { label: "All News", href: "/news/", desc: "Everything published" },
                { label: "Features", href: "/news/format/feature/", desc: "In-depth reporting" },
                { label: "News Analysis", href: "/news/format/news-analysis/", desc: "What it means" },
                { label: "Case Studies", href: "/news/format/case-study/", desc: "Real-world impact" },
                { label: "Releases", href: "/news/format/release-note/", desc: "Product launches" },
                { label: "Interviews", href: "/news/format/interview/", desc: "Conversations with leaders" },
              ].map((item) => (
                <a href={item.href} class="flex flex-col px-4 py-3 rounded-lg hover:bg-white/[0.06] transition-colors">
                  <span class="text-[15px] font-semibold text-[#e0e0e0] hover:text-white">{item.label}</span>
                  <span class="text-[12px] text-[#666] mt-0.5">{item.desc}</span>
                </a>
              ))}
            </div>
          </div>
        </div>

        {/* Themes dropdown */}
        <div class="relative" id="themes-dropdown-wrap">
          <button class="text-[13px] font-medium text-white/60 hover:text-white transition-colors flex items-center gap-1" id="themes-trigger">
            Themes
            <svg class="w-3 h-3 opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
          </button>
          <div class="absolute top-full left-0 mt-3 w-[560px] rounded-xl shadow-2xl p-6 z-50 hidden border border-[#2a2a2a]" id="themes-dropdown" style="background: linear-gradient(165deg, #1a1a1a 0%, #111 100%);">
            <div class="flex items-center justify-between mb-4">
              <span class="text-[11px] font-semibold text-[#777] uppercase tracking-wider">Explore themes</span>
              <a href="/themes/" class="text-[12px] text-[#ff6b4a] hover:text-[#ff8566] font-semibold">View all →</a>
            </div>
            <div class="grid grid-cols-2 gap-1">
              {[
                { label: "AI Product Strategy", slug: "ai-product-strategy", color: "#ff6b4a" },
                { label: "Agents & Agentic Systems", slug: "agents-agentic-systems", color: "#9b7bff" },
                { label: "UX & Design for AI", slug: "ux-experience-design-for-ai", color: "#4ab8c9" },
                { label: "Adoption & Org Change", slug: "adoption-organizational-change", color: "#f5a623" },
                { label: "Evaluation & Benchmarking", slug: "evaluation-benchmarking", color: "#6bbf71" },
                { label: "Go-to-Market", slug: "go-to-market-distribution", color: "#ff8566" },
                { label: "Data & Knowledge", slug: "data-semantics-knowledge-foundations", color: "#5ba3cc" },
                { label: "Governance & Trust", slug: "governance-risk-trust", color: "#c96bff" },
              ].map((t) => (
                <a href={`/themes/${t.slug}/`} class="flex items-center gap-3 px-4 py-3 rounded-lg hover:bg-white/[0.06] transition-colors">
                  <div class="w-2.5 h-2.5 rounded-full flex-shrink-0" style={`background: ${t.color}; box-shadow: 0 0 8px ${t.color}40`}></div>
                  <span class="text-[15px] font-semibold text-[#e0e0e0] hover:text-white">{t.label}</span>
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>

      {/* Center logo — compact on mobile, large on desktop. JS only adjusts
          desktop sizes on scroll; mobile sticks at 48px. */}
      <a href="/" class="flex items-center justify-center flex-shrink-0">
        <img
          src="/nav-logo-full.png"
          alt="Product Impact Podcast"
          class="object-contain transition-all duration-300 w-auto h-12 md:w-[300px] md:h-[300px]"
          id="nav-logo"
        />
      </a>

      {/* Right nav items */}
      <div class="hidden md:flex items-center justify-end gap-6 flex-1">
        <a href="/podcast/" class="text-[13px] font-medium text-white/60 hover:text-white transition-colors">Podcast</a>
        <a href="/episodes/" class="text-[13px] font-medium text-white/60 hover:text-white transition-colors">Episodes</a>
        <a href="/partnerships/" class="text-[13px] font-medium text-white/60 hover:text-white transition-colors">Partner</a>
      </div>

      {/* Mobile hamburger — 44×44 tap target */}
      <button
        type="button"
        aria-label="Menu"
        aria-expanded="false"
        aria-controls="nav-menu"
        class="md:hidden p-3 -mr-2 text-white/60 hover:text-white"
        id="nav-toggle"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="4" y1="6" x2="20" y2="6"></line>
          <line x1="4" y1="12" x2="20" y2="12"></line>
          <line x1="4" y1="18" x2="20" y2="18"></line>
        </svg>
      </button>
    </div>

    {/* Mobile menu — full inventory, scrollable, closes on link tap */}
    <div id="nav-menu" class="md:hidden hidden border-t border-white/5 bg-[#0a0a0a]/95 backdrop-blur-md max-h-[calc(100dvh-64px)] overflow-y-auto">
      <div class="py-4 px-6">
        <div class="text-[10px] font-semibold uppercase tracking-wider text-[#555] mb-2">Browse</div>
        <a href="/news/" class="block py-3 text-[15px] font-medium text-white/80 hover:text-white nav-menu-link">News</a>
        <a href="/themes/" class="block py-3 text-[15px] font-medium text-white/80 hover:text-white nav-menu-link">Themes</a>
        <a href="/podcast/" class="block py-3 text-[15px] font-medium text-white/80 hover:text-white nav-menu-link">Podcast</a>
        <a href="/episodes/" class="block py-3 text-[15px] font-medium text-white/80 hover:text-white nav-menu-link">Episodes</a>

        <div class="text-[10px] font-semibold uppercase tracking-wider text-[#555] mt-5 mb-2">Entities</div>
        <a href="/people/" class="block py-3 text-[14px] text-white/70 hover:text-white nav-menu-link">People</a>
        <a href="/organizations/" class="block py-3 text-[14px] text-white/70 hover:text-white nav-menu-link">Organizations</a>
        <a href="/products/" class="block py-3 text-[14px] text-white/70 hover:text-white nav-menu-link">Products</a>
        <a href="/concepts/" class="block py-3 text-[14px] text-white/70 hover:text-white nav-menu-link">Concepts</a>
        <a href="/frameworks/" class="block py-3 text-[14px] text-white/70 hover:text-white nav-menu-link">Frameworks</a>
        <a href="/sources/" class="block py-3 text-[14px] text-white/70 hover:text-white nav-menu-link">Sources</a>

        <div class="text-[10px] font-semibold uppercase tracking-wider text-[#555] mt-5 mb-2">Connect</div>
        <a href="/partnerships/" class="block py-3 text-[14px] text-[#ff6b4a] hover:text-[#ff8566] nav-menu-link">Partner with us</a>
        <a href="/about/" class="block py-3 text-[14px] text-white/70 hover:text-white nav-menu-link">About</a>
        <a href="/contact/" class="block py-3 text-[14px] text-white/70 hover:text-white nav-menu-link">Contact</a>
      </div>
    </div>
  </nav>
  {/* Spacer — matches expanded nav height per breakpoint */}
  <div class="h-[64px] md:h-[120px]"></div>
</header>

<script is:inline>
(function() {
  var nav = document.getElementById('main-nav');
  var inner = document.getElementById('nav-inner');
  var logo = document.getElementById('nav-logo');
  var toggle = document.getElementById('nav-toggle');
  var menu = document.getElementById('nav-menu');

  if (!nav || !inner || !logo) return;

  var DESKTOP_BP = 768;

  // Apply scroll-driven sizing only on desktop. On mobile, the responsive
  // Tailwind classes (h-[64px], h-12 logo) own the sizing — never touched
  // by JS.
  function applyScrollState(scrolled) {
    nav.style.background = scrolled ? 'rgba(8,8,8,0.95)' : 'rgba(8,8,8,0.6)';
    nav.style.backdropFilter = scrolled ? 'blur(12px)' : 'blur(8px)';
    nav.style.borderColor = scrolled ? 'rgba(255,255,255,0.06)' : 'transparent';

    if (window.innerWidth >= DESKTOP_BP) {
      inner.style.height = scrolled ? '80px' : '120px';
      logo.style.width = scrolled ? '200px' : '300px';
      logo.style.height = scrolled ? '200px' : '300px';
    } else {
      // Mobile: clear any inline desktop overrides so Tailwind classes win.
      inner.style.height = '';
      logo.style.width = '';
      logo.style.height = '';
    }
  }

  var scrolled = false;
  function onScroll() {
    var now = window.scrollY > 40;
    if (now !== scrolled) {
      scrolled = now;
      applyScrollState(scrolled);
    }
  }
  window.addEventListener('scroll', onScroll, { passive: true });

  // On resize across the desktop breakpoint, reapply sizing so we don't
  // leak desktop inline px-values into mobile.
  window.addEventListener('resize', function() {
    applyScrollState(scrolled);
  }, { passive: true });

  // Initial paint
  applyScrollState(false);

  // Mobile toggle (with aria-expanded)
  if (toggle && menu) {
    toggle.addEventListener('click', function() {
      var isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      toggle.setAttribute('aria-expanded', String(!isOpen));
    });
    // Close menu when any link inside it is tapped
    menu.querySelectorAll('.nav-menu-link').forEach(function(link) {
      link.addEventListener('click', function() {
        menu.classList.add('hidden');
        toggle.setAttribute('aria-expanded', 'false');
      });
    });
    // Close on resize past mobile breakpoint
    window.addEventListener('resize', function() {
      if (window.innerWidth >= DESKTOP_BP) {
        menu.classList.add('hidden');
        toggle.setAttribute('aria-expanded', 'false');
      }
    }, { passive: true });
  }

  // Mega menu dropdowns (desktop only)
  function setupDropdown(triggerId, dropdownId, wrapId) {
    var trigger = document.getElementById(triggerId);
    var dropdown = document.getElementById(dropdownId);
    var wrap = document.getElementById(wrapId);
    if (!trigger || !dropdown || !wrap) return;
    var timeout;

    function show() { clearTimeout(timeout); dropdown.classList.remove('hidden'); }
    function hide() { timeout = setTimeout(function() { dropdown.classList.add('hidden'); }, 150); }

    wrap.addEventListener('mouseenter', show);
    wrap.addEventListener('mouseleave', hide);
    trigger.addEventListener('click', function(e) {
      e.preventDefault();
      dropdown.classList.toggle('hidden');
    });
    document.addEventListener('click', function(e) {
      if (!wrap.contains(e.target)) dropdown.classList.add('hidden');
    });
  }

  setupDropdown('news-trigger', 'news-dropdown', 'news-dropdown-wrap');
  setupDropdown('themes-trigger', 'themes-dropdown', 'themes-dropdown-wrap');
})();
</script>
