# productimpactpod.com — environment variables
# Copy to .env for local development.

# ─── Supabase ────────────────────────────────────────────────────────────────
# Both values come from your Supabase project — Dashboard → Settings → API.
# PUBLIC_ prefix means Astro exposes them to the build, so they ship in the
# compiled site (fine: anon key is subject to RLS; URL is public).
PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# ─── Cloudflare Pages ────────────────────────────────────────────────────────
# These go in the Cloudflare Pages dashboard (Project → Settings →
# Environment variables), NOT here. Listed for reference only.
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=

# ─── Publisher-only (NEVER commit — belongs in ~/.env, vault .env, etc.) ─────
# These are used by scripts/publishing/ tools when publish_articles.py runs
# from vault-system. The site itself doesn't need them.
# ANTHROPIC_API_KEY=sk-ant-api03-...
# REPLICATE_API_TOKEN=r8_...
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...            # secret! bypasses RLS
# GITHUB_TOKEN=ghp_...                                # for dispatch_rebuild.py
