from pathlib import Path

# ── Path wiring ────────────────────────────────────────────────────────────
# Submodule path — site repo lives at scripts/site under vault-system
THIS_FILE = Path(__file__).resolve()
VAULT_ROOT = THIS_FILE.parent.parent.parent   # vault-system root
SITE_DIR = THIS_FILE.parent / "site"           # submodule checkout
PUBLISHING_DIR = SITE_DIR / "scripts" / "publishing"

if not PUBLISHING_DIR.exists():
    print(f"✗ site submodule not initialised. Run:", file=sys.stderr)
    print(f"    cd {VAULT_ROOT} && git submodule update --init --recursive", file=sys.stderr)
    sys.exit(2)

sys.path.insert(0, str(PUBLISHING_DIR))
from validate_article import validate, has_errors      # noqa: E402
from generate_hero_image import generate as generate_hero  # noqa: E402
from dispatch_rebuild import dispatch                  # noqa: E402

# ── Supabase client ────────────────────────────────────────────────────────
try:
    from supabase import create_client, Client
except ImportError:
    print("✗ pip install supabase", file=sys.stderr)
    sys.exit(2)

SUPABASE_URL = os.environ.get("PUBLIC_SUPABASE_URL", "https://cyqkfkvsrdbbjuaqiglx.supabase.co")
SERVICE_KEY = os.environ.get("SUPABASE_SERVICE_ROLE_KEY")
if not SERVICE_KEY:
    print("✗ SUPABASE_SERVICE_ROLE_KEY not set", file=sys.stderr)
    sys.exit(2)

sb: Client = create_client(SUPABASE_URL, SERVICE_KEY)

# ── Logging ────────────────────────────────────────────────────────────────

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s %(levelname)-7s %(message)s",
    datefmt="%H:%M:%S",
)
log = logging.getLogger("publish")


