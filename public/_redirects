# Cloudflare Pages redirects — Netlify-compatible syntax.
# Format: <from> <to> <status>
#
# Migration from the Lovable-era URL structure (arpyph1/product-impact-podcast-web).
# Most paths (/news/[slug], /themes/[slug], /people/[slug], /concepts/[slug],
# /organizations/[slug], /products/[slug], /frameworks/[slug], /sources/[slug],
# /partnerships) match identically between the two sites — no redirect needed.
#
# Differences:
#   Lovable: /      → podcast home     |  /hub  → content home
#   Astro:   /      → content home     |  /podcast → podcast home
#
# /hub was the canonical content-hub URL on Lovable; redirect to new homepage.

/hub                /                              301
/hub/               /                              301

# Legacy listen-link subpaths that may have been scraped from Lovable
/home               /                              301
/index              /                              301

# Trailing slash hygiene — Cloudflare Pages serves both forms by default, but
# these explicit 301s ensure canonical consistency when crawlers follow both.
# (The Astro build emits /news/ directory-style paths per astro.config.mjs
# build.format="directory", so trailing slashes are the canonical form.)

# Known legacy article-path shapes from early Lovable drafts (if any exist in
# the wild, they redirect; if not, they 404 harmlessly without this file).
/articles/*         /news/:splat                   301
/article/*          /news/:splat                   301
/post/*             /news/:splat                   301

# Category → theme migration (some Lovable-era links may have used /category/)
/category/*         /themes/:splat                 301

# RSS feed URL canonicalisation — legacy variants
/feed               /rss.xml                       301
/feed.xml           /rss.xml                       301
/atom.xml           /rss.xml                       301
/news/feed          /news/rss.xml                  301
/news/feed.xml      /news/rss.xml                  301

# Sitemap canonicalisation
/sitemap            /sitemap.xml                   301
/sitemap_index.xml  /sitemap.xml                   301

# Legacy episode URLs — early podcast pages lived under /podcast/{slug}/
# before episodes moved to /episodes/{slug}/. Catch-all forwards them.
# Specific overrides come first for two known legacy slugs whose target
# /episodes/{slug} doesn't exist — point them at the closest real page
# so Search Console doesn't see a redirect-then-404.
#
# IMPORTANT: explicit /podcast and /podcast/ guards MUST come before the
# /podcast/* catch-all. Otherwise the catch-all matches the bare podcast
# index with an empty splat and 301s readers to /episodes/.
/podcast                                                              /podcast/                 301
/podcast/                                                             /podcast/                 200
/podcast/robert-brunner-physical-ai                                   /people/robert-brunner/   301
/podcast/cognitive-sovereignty-helen-dave-edwards-artificiality-institute  /episodes/                301
/podcast/*          /episodes/:splat               301

# Topic & tag pages: trailing-slash-only catch-all for dead slugs.
#
# Background: with format:"directory", Cloudflare Pages serves
# /topics/foo/ from /topics/foo/index.html. When that file doesn't
# exist (topic deleted or merged), Cloudflare's auto-trailing-slash
# logic can ping-pong /topics/foo ↔ /topics/foo/ and Googlebot reports
# it as "Redirect error" — that's what 100+ topic URLs hit in GSC.
#
# The fix is a placeholder rule that matches *only* the trailing-slash
# form. Static assets take precedence, so live topic hubs serve 200.
# Dead slugs (no static file) fall through to the rule and 301 to the
# index. The no-trailing-slash variant /topics/foo doesn't match this
# pattern, so it still gets Cloudflare's standard auto-301 to
# /topics/foo/ (which then either serves 200 or matches this rule —
# either way, no loop).
#
# The previous `/topics/* → /topics/ 301` catch-all caused the inverse
# problem: it matched the no-slash variants of *live* topics and 301'd
# them to /topics/ instead of the canonical trailing-slash form. The
# `:slug/` placeholder syntax avoids that by requiring a trailing slash
# in the request path.
/topics/:slug/      /topics/                       301
/tags/:slug/        /tags/                         301

# Social/unfurl bot compatibility — some platforms strip trailing slashes
# and re-append with quotes. These are harmless no-ops if never hit.
